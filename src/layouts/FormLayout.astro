---
import Base from './Base.astro';
import { strings } from '../lib/strings.js';

interface Props {
  title: string;
  formId: string;
}

const { title, formId } = Astro.props;
---

<Base title={title}>
  <div class="max-w-5xl mx-auto py-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4 bg-white p-6 rounded-3xl shadow-sm border border-slate-100">
      <div class="flex items-center gap-4">
        <a href="/dashboard" class="p-2 bg-slate-50 hover:bg-blue-50 text-slate-500 hover:text-blue-600 rounded-full transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
        <div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm font-bold rounded-lg border border-blue-200">
              {formId}
            </span>
            <h1 class="text-2xl font-bold text-slate-800">{title}</h1>
          </div>
        </div>
      </div>
      
      <!-- Save Indicator -->
      <div id="save-indicator" class="flex items-center gap-2 opacity-0 transition-opacity duration-300">
        <div id="save-spinner" class="hidden w-5 h-5 border-2 border-slate-200 border-t-amber-500 rounded-full animate-spin"></div>
        <svg id="save-check" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span id="save-text" class="text-sm font-semibold text-slate-500"></span>
      </div>
    </div>

    <!-- Form Content -->
    <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/20 border border-slate-100 overflow-hidden mb-8">
      <slot />
    </div>
    
    <!-- Footer Actions -->
    <div class="flex justify-between items-center bg-white p-6 rounded-3xl shadow-sm border border-slate-100">
      <a href="/dashboard" class="px-6 py-3 border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-slate-600 font-semibold rounded-xl transition-colors">
        {strings.dashboard.title}
      </a>
      
      <slot name="footer-action" />
    </div>
  </div>
</Base>
