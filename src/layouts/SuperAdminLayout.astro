---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { strings } from '../lib/strings.js';

interface Props {
  title?: string;
  activePath?: string;
}

const { title = strings.superAdmin.dashboard, activePath = '/superadmin/dashboard' } = Astro.props;

const menuItems = [
  { path: '/superadmin/dashboard', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'ড্যাশবোর্ড' },
  { path: '/superadmin/cycles', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', label: strings.superAdmin.cycles.title },
  { path: '/superadmin/rates', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z', label: strings.superAdmin.rates.title },
  { path: '/superadmin/expense-codes', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', label: strings.superAdmin.codes.title },
  { path: '/superadmin/admins', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', label: strings.superAdmin.admins.title },
  { path: '/superadmin/submissions', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', label: 'দাখিলকৃত বাজেট' },
];
---

<!DOCTYPE html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {strings.appName}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 flex selection:bg-blue-200">
    
    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-slate-100 flex flex-col fixed inset-y-0 left-0 z-50">
      <div class="p-6 border-b border-slate-800">
        <h1 class="font-bold text-xl leading-tight text-white">{strings.appName}</h1>
        <p class="text-blue-400 text-sm mt-1">{strings.superAdmin.dashboard}</p>
      </div>

      <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
        {menuItems.map(item => {
          const isActive = activePath === item.path;
          return (
            <a 
              href={item.path} 
              class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 ${isActive ? 'bg-blue-600 text-white shadow-md shadow-blue-600/20 font-medium' : 'text-slate-300 hover:bg-slate-800 hover:text-white'}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
              {item.label}
            </a>
          )
        })}
      </nav>

      <div class="p-4 border-t border-slate-800">
        <div class="flex items-center gap-3 px-4 py-3 mb-2 rounded-xl bg-slate-800/50 border border-slate-700/50">
           <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-white font-bold text-sm">
             SA
           </div>
           <div>
             <div class="text-sm font-bold text-white leading-none" id="sa-username">--</div>
             <div class="text-xs text-indigo-300 mt-1">SuperAdmin</div>
           </div>
        </div>
        
        <button id="logout-btn" class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-rose-400 hover:bg-rose-500/10 hover:text-rose-300 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          {strings.admin.login.logout}
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8 min-h-screen flex flex-col">
      <slot />
    </main>

  </body>
</html>

<script>
  import { supabase } from '../lib/supabase.js';

  document.addEventListener('astro:page-load', async () => {
    // 1. Check Session Storage first for fast fail
    const saUser = sessionStorage.getItem('sa_username');
    if (!saUser) {
      window.location.href = '/superadmin/login';
      return;
    }
    
    // Display Username
    const userEl = document.getElementById('sa-username');
    if (userEl) userEl.textContent = saUser;

    // 2. Verify Session via Supabase
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      sessionStorage.removeItem('sa_username');
      window.location.href = '/superadmin/login';
      return;
    }

    // 3. Optional: Re-verify role if needed
    // In a highly secure app, we'd verify admin_profiles here too.
    // For now, if they have sa_username and a session, we let them view.

    // 4. Logout handler
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', async () => {
        logoutBtn.innerHTML = 'লগআউট হচ্ছে...';
        await supabase.auth.signOut();
        sessionStorage.removeItem('sa_username');
        window.location.href = '/superadmin/login';
      });
    }
  });
</script>
