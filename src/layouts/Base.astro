---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { strings } from '../lib/strings.js';

interface Props {
  title?: string;
  fullWidth?: boolean;
}

const { title = strings.appName, fullWidth = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 selection:bg-blue-200 flex flex-col">
    <slot name="full-width-header" />
    <main class={fullWidth ? "flex-grow flex flex-col w-full" : "container mx-auto px-4 py-3 max-w-5xl flex-grow"}>
      <slot />
    </main>
  </body>
</html>
