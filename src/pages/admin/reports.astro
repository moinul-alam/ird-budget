---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-6xl mx-auto">
      <a href="/admin/dashboard" class="text-blue-600 mb-4 inline-block">&larr; পিছনে</a>
      <h1 class="text-2xl font-bold mb-6">রিপোর্ট</h1>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold mb-2">অফিস বাজেট রিপোর্ট</h3>
          <p class="text-sm text-gray-600 mb-4">নির্দিষ্ট অফিসের বাজেট রিপোর্ট</p>
          <select id="office-select" class="w-full p-2 border border-gray-300 rounded mb-4">
            <option value="">অফিস নির্বাচন করুন</option>
          </select>
          <button id="office-report-btn" class="w-full bg-blue-600 text-white p-2 rounded hover:bg-blue-700">রিপোর্ট তৈরি করুন</button>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold mb-2">গ্রুপ কনসোলিডেটেড রিপোর্ট</h3>
          <p class="text-sm text-gray-600 mb-4">নির্দিষ্ট গ্রুপের সব অফিসের রিপোর্ট</p>
          <select id="group-select" class="w-full p-2 border border-gray-300 rounded mb-4">
            <option value="">গ্রুপ নির্বাচন করুন</option>
          </select>
          <button id="group-report-btn" class="w-full bg-green-600 text-white p-2 rounded hover:bg-green-700">রিপোর্ট তৈরি করুন</button>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold mb-2">কোড-ওয়াইজ কনসোলিডেটেড রিপোর্ট</h3>
          <p class="text-sm text-gray-600 mb-4">নির্দিষ্ট গ্রুপের কোড অনুযায়ী রিপোর্ট</p>
          <select id="code-group-select" class="w-full p-2 border border-gray-300 rounded mb-4">
            <option value="">গ্রুপ নির্বাচন করুন</option>
          </select>
          <button id="code-report-btn" class="w-full bg-purple-600 text-white p-2 rounded hover:bg-purple-700">রিপোর্ট তৈরি করুন</button>
        </div>
      </div>
    </div>
  </div>
  <script>
    import { supabase } from '../../lib/supabase';
    import { printReport } from '../../lib/report';
    import { toBanglaCurrency, toBanglaDate } from '../../lib/bangla';

    async function loadSelects() {
      const { data: offices } = await supabase.from('offices').select('*');
      const officeSelect = document.getElementById('office-select');
      (offices || []).forEach(office => {
        const option = document.createElement('option');
        option.value = office.id;
        option.textContent = `${office.office_id} - ${office.name}`;
        officeSelect.appendChild(option);
      });

      const { data: groups } = await supabase.from('office_groups').select('*');
      const groupSelect = document.getElementById('group-select');
      const codeGroupSelect = document.getElementById('code-group-select');
      (groups || []).forEach(group => {
        const option1 = document.createElement('option');
        option1.value = group.id;
        option1.textContent = group.name;
        groupSelect.appendChild(option1);

        const option2 = document.createElement('option');
        option2.value = group.id;
        option2.textContent = group.name;
        codeGroupSelect.appendChild(option2);
      });
    }

    async function generateOfficeReport(officeId) {
      const { data: office } = await supabase.from('offices').select('*').eq('id', officeId).single();
      const { data: submission } = await supabase.from('submissions').select('*, budget_sheet(*, expense_codes(*))').eq('office_id', officeId).maybeSingle();

      const html = `
        <div>
          <h1 style="font-size: 24px; font-weight: bold; text-align: center; margin-bottom: 8px;">${office.name}</h1>
          <p style="text-align: center; margin-bottom: 4px;">অফিস কোড: ${office.office_id}</p>
          <p style="text-align: center; margin-bottom: 24px;">জেনারেটেড: ${toBanglaDate(new Date().toISOString())}</p>
          <table style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr style="background: #f3f4f6;">
                <th style="border: 1px solid #333; padding: 8px; text-align: left;">কোড</th>
                <th style="border: 1px solid #333; padding: 8px; text-align: left;">ব্যয় খাত</th>
                <th style="border: 1px solid #333; padding: 8px; text-align: right;">পরিমাণ</th>
              </tr>
            </thead>
            <tbody>
              ${(submission?.budget_sheet || []).map(row => `
                <tr>
                  <td style="border: 1px solid #333; padding: 8px;">${row.expense_codes.code}</td>
                  <td style="border: 1px solid #333; padding: 8px;">${row.expense_codes.name}</td>
                  <td style="border: 1px solid #333; padding: 8px; text-align: right;">${toBanglaCurrency(row.final_value)}</td>
                </tr>
              `).join('')}
            </tbody>
            <tfoot>
              <tr style="font-weight: bold;">
                <td style="border: 1px solid #333; padding: 8px;" colspan="2">মোট</td>
                <td style="border: 1px solid #333; padding: 8px; text-align: right;">${toBanglaCurrency((submission?.budget_sheet || []).reduce((sum, row) => sum + (row.final_value || 0), 0))}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      `;
      printReport(html);
    }

    async function generateGroupReport(groupId) {
      const { data: group } = await supabase.from('office_groups').select('*').eq('id', groupId).single();
      const { data: offices } = await supabase.from('offices').select('*, submissions(*, budget_sheet(*))').eq('group_id', groupId);

      const html = `
        <div>
          <h1 style="font-size: 24px; font-weight: bold; text-align: center; margin-bottom: 8px;">গ্রুপ: ${group.name}</h1>
          <p style="text-align: center; margin-bottom: 24px;">জেনারেটেড: ${toBanglaDate(new Date().toISOString())}</p>
          <table style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr style="background: #f3f4f6;">
                <th style="border: 1px solid #333; padding: 8px; text-align: left;">অফিস কোড</th>
                <th style="border: 1px solid #333; padding: 8px; text-align: left;">অফিসের নাম</th>
                <th style="border: 1px solid #333; padding: 8px; text-align: right;">মোট বাজেট</th>
                <th style="border: 1px solid #333; padding: 8px; text-align: left;">অবস্থা</th>
              </tr>
            </thead>
            <tbody>
              ${(offices || []).map(office => {
                const submission = office.submissions?.[0];
                const total = (submission?.budget_sheet || []).reduce((sum, row) => sum + (row.final_value || 0), 0);
                return `
                  <tr>
                    <td style="border: 1px solid #333; padding: 8px;">${office.office_id}</td>
                    <td style="border: 1px solid #333; padding: 8px;">${office.name}</td>
                    <td style="border: 1px solid #333; padding: 8px; text-align: right;">${toBanglaCurrency(total)}</td>
                    <td style="border: 1px solid #333; padding: 8px;">${submission?.status === 'submitted' ? 'দাখিলকৃত' : 'খসড়া'}</td>
                  </tr>
                `;
              }).join('')}
            </tbody>
            <tfoot>
              <tr style="font-weight: bold;">
                <td style="border: 1px solid #333; padding: 8px;" colspan="2">গ্রুপ মোট</td>
                <td style="border: 1px solid #333; padding: 8px; text-align: right;">${toBanglaCurrency((offices || []).reduce((sum, office) => {
                  const submission = office.submissions?.[0];
                  return sum + (submission?.budget_sheet || []).reduce((s, row) => s + (row.final_value || 0), 0);
                }, 0))}</td>
                <td style="border: 1px solid #333; padding: 8px;"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      `;
      printReport(html);
    }

    async function generateCodeReport(groupId) {
      const { data: group } = await supabase.from('office_groups').select('*').eq('id', groupId).single();
      const { data: offices } = await supabase.from('offices').select('*, submissions(*, budget_sheet(*, expense_codes(*)))').eq('group_id', groupId);
      const { data: codes } = await supabase.from('expense_codes').select('*').order('sort_order');

      const html = `
        <div>
          <h1 style="font-size: 24px; font-weight: bold; text-align: center; margin-bottom: 8px;">গ্রুপ: ${group.name} - কোড-ওয়াইজ রিপোর্ট</h1>
          <p style="text-align: center; margin-bottom: 24px;">জেনারেটেড: ${toBanglaDate(new Date().toISOString())}</p>
          <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
            <thead>
              <tr style="background: #f3f4f6;">
                <th style="border: 1px solid #333; padding: 4px; text-align: left;">কোড</th>
                <th style="border: 1px solid #333; padding: 4px; text-align: left;">ব্যয় খাত</th>
                ${(offices || []).map(office => `<th style="border: 1px solid #333; padding: 4px; text-align: right;">${office.office_id}</th>`).join('')}
                <th style="border: 1px solid #333; padding: 4px; text-align: right;">মোট</th>
              </tr>
            </thead>
            <tbody>
              ${(codes || []).map(code => {
                const codeTotals = (offices || []).map(office => {
                  const submission = office.submissions?.[0];
                  const row = (submission?.budget_sheet || []).find(r => r.code_id === code.id);
                  return row?.final_value || 0;
                });
                const total = codeTotals.reduce((sum, val) => sum + val, 0);
                return `
                  <tr>
                    <td style="border: 1px solid #333; padding: 4px;">${code.code}</td>
                    <td style="border: 1px solid #333; padding: 4px;">${code.name}</td>
                    ${codeTotals.map(val => `<td style="border: 1px solid #333; padding: 4px; text-align: right;">${toBanglaCurrency(val)}</td>`).join('')}
                    <td style="border: 1px solid #333; padding: 4px; text-align: right; font-weight: bold;">${toBanglaCurrency(total)}</td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        </div>
      `;
      printReport(html);
    }

    document.getElementById('office-report-btn').addEventListener('click', () => {
      const officeId = document.getElementById('office-select').value;
      if (officeId) generateOfficeReport(officeId);
    });

    document.getElementById('group-report-btn').addEventListener('click', () => {
      const groupId = document.getElementById('group-select').value;
      if (groupId) generateGroupReport(groupId);
    });

    document.getElementById('code-report-btn').addEventListener('click', () => {
      const groupId = document.getElementById('code-group-select').value;
      if (groupId) generateCodeReport(groupId);
    });

    loadSelects();
  </script>
</Layout>
