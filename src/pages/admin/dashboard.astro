---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">অ্যাডমিন ড্যাশবোর্ড</h1>
        <button id="logout-btn" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">লগআউট</button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white p-4 rounded shadow">
          <h3 class="font-bold">মোট অফিস</h3>
          <p id="total-offices" class="text-3xl">0</p>
        </div>
        <div class="bg-white p-4 rounded shadow">
          <h3 class="font-bold">দাখিলকৃত</h3>
          <p id="submitted" class="text-3xl">0</p>
        </div>
        <div class="bg-white p-4 rounded shadow">
          <h3 class="font-bold">খসড়া</h3>
          <p id="drafts" class="text-3xl">0</p>
        </div>
      </div>
      <h2 class="text-xl font-bold mb-4">অফিস তালিকা</h2>
      <div class="bg-white rounded shadow overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100">
            <tr>
              <th class="p-3 text-left">অফিস কোড</th>
              <th class="p-3 text-left">অফিসের নাম</th>
              <th class="p-3 text-left">অবস্থা</th>
              <th class="p-3 text-left">কার্যক্রম</th>
            </tr>
          </thead>
          <tbody id="offices-table"></tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    import { supabase } from '../../lib/supabase';

    async function checkAuth() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) {
        window.location.href = '/admin/login';
        return;
      }
      const { data: profile } = await supabase.from('admin_profiles').select('*').eq('id', user.id).single();
      if (profile?.role === 'superadmin') {
        window.location.href = '/superadmin/dashboard';
      }
    }

    document.getElementById('logout-btn').addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login';
    });

    async function loadDashboard() {
      const { data: offices } = await supabase.from('offices').select('*, submissions(*)');
      document.getElementById('total-offices').textContent = (offices || []).length;
      const submitted = (offices || []).filter(o => o.submissions?.some(s => s.status === 'submitted')).length;
      const drafts = (offices || []).filter(o => o.submissions?.some(s => s.status === 'draft')).length;
      document.getElementById('submitted').textContent = submitted;
      document.getElementById('drafts').textContent = drafts;

      const table = document.getElementById('offices-table');
      table.innerHTML = (offices || []).map(office => `
        <tr class="border-b">
          <td class="p-3">${office.office_id}</td>
          <td class="p-3">${office.name}</td>
          <td class="p-3">${office.submissions?.[0]?.status === 'submitted' ? 'দাখিলকৃত' : 'খসড়া'}</td>
          <td class="p-3">
            <a href="/admin/reports?office=${office.id}" class="text-blue-600 hover:underline">রিপোর্ট</a>
          </td>
        </tr>
      `).join('');
    }

    checkAuth();
    loadDashboard();
  </script>
</Layout>
