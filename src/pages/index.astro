---
import Base from "../layouts/Base.astro";
import { strings } from "../lib/strings.js";
---

<Base title={strings.landing.title} fullWidth={true}>
  <style>
    @keyframes pulse-slow {
      0%,
      100% {
        transform: scale(1);
        opacity: 0.8;
      }
      50% {
        transform: scale(1.05);
        opacity: 0.5;
      }
    }
    .animate-pulse-slow {
      animation: pulse-slow 8s infinite ease-in-out;
    }
  </style>
  <div
    class="flex-grow flex flex-col items-center justify-center relative overflow-hidden px-4 py-8"
  >
    <!-- Decorative Background Elements -->
    <div
      class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-blue-500/20 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"
    >
    </div>
    <div
      class="absolute bottom-[-10%] right-[-10%] w-[35rem] h-[35rem] bg-indigo-500/20 rounded-full blur-[100px] pointer-events-none animate-pulse-slow"
      style="animation-delay: -4s;"
    >
    </div>
    <div
      class="absolute top-[20%] right-[15%] w-[25rem] h-[25rem] bg-purple-400/10 rounded-full blur-[80px] pointer-events-none"
    >
    </div>

    <!-- Admin Login -->
    <div class="absolute top-4 right-4 sm:top-6 sm:right-6 z-50">
      <a
        href="/superadmin/login"
        title={strings.landing.adminLogin}
        class="group flex items-center justify-center w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-white/40 hover:bg-white/40 hover:scale-110 transition-all duration-300 shadow-lg"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6 text-slate-500 group-hover:text-blue-600 transition-colors"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
          ></path>
        </svg>
      </a>
    </div>

    <!-- Main Card -->
    <div
      id="main-card"
      class="relative w-full max-w-3xl transition-all duration-700 ease-in-out bg-white/60 backdrop-blur-2xl border border-white/60 shadow-[0_8px_40px_rgb(0,0,0,0.06)] rounded-[2.5rem] p-8 sm:p-12 overflow-hidden z-10"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-white/80 to-white/20 pointer-events-none"
      >
      </div>

      <!-- Header -->
      <div class="relative text-center mb-12">
        <div
          class="w-24 h-24 mx-auto flex items-center justify-center mb-6 transform hover:scale-110 transition-transform duration-500"
        >
          <img
            src="/images/bdgovlogo.png"
            alt="Government Logo"
            class="w-full h-full object-contain drop-shadow-xl"
          />
        </div>
        <h1
          class="text-4xl md:text-5xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-blue-700 via-indigo-700 to-blue-900 mb-4 drop-shadow-sm"
        >
          {strings.landing.title}
        </h1>
        <p class="text-slate-500 font-medium text-lg max-w-xl mx-auto">
          {strings.landing.subtitle}
        </p>
      </div>

      <!-- Split layout container -->
      <div
        id="split-container"
        class="relative flex flex-col md:flex-row gap-8 items-start justify-center transition-all duration-500"
      >
        <!-- LEFT: Search panel -->
        <div
          id="search-panel"
          class="w-full max-w-md transition-all duration-500 ease-out z-10 shrink-0"
        >
          <form id="search-form" class="space-y-6">
            <div class="group">
              <label
                for="budget_id"
                class="block text-sm font-bold text-slate-700 mb-2 ml-1"
              >
                {strings.landing.enterBudgetId}
              </label>
              <div class="relative">
                <input
                  type="text"
                  id="budget_id"
                  name="budget_id"
                  placeholder={strings.landing.budgetIdPlaceholder}
                  class="w-full px-6 py-4 bg-white/80 backdrop-blur-md border-2 border-slate-100 rounded-2xl text-lg font-semibold text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all duration-300 shadow-sm hover:border-blue-300"
                  required
                />
                <div
                  class="absolute inset-y-0 right-5 flex items-center pointer-events-none text-blue-500/50 group-hover:text-blue-500 transition-colors duration-300"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div class="flex gap-4">
              <button
                type="button"
                id="open-register-modal-btn"
                class="flex-[0.4] bg-white/80 border-2 border-slate-100 hover:border-blue-300 hover:bg-blue-50/80 text-slate-600 hover:text-blue-700 font-bold py-4 px-4 rounded-2xl transition-all duration-300 shadow-sm hover:shadow flex items-center justify-center gap-2 group backdrop-blur-md"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-slate-400 group-hover:text-blue-500 transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 4v16m8-8H4"></path>
                </svg>
                <span class="text-base whitespace-nowrap"
                  >{strings.landing.registerButton}</span
                >
              </button>
              <button
                type="submit"
                id="search-btn"
                class="flex-[0.6] relative overflow-hidden bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold text-lg py-4 px-6 rounded-2xl shadow-[0_8px_20px_rgb(79,70,229,0.3)] hover:shadow-[0_8px_25px_rgb(79,70,229,0.45)] transition-all duration-300 active:scale-[0.98] flex justify-center items-center gap-2 group"
              >
                <div
                  class="absolute inset-0 w-full h-full bg-white/20 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"
                >
                </div>
                <span id="search-btn-text" class="relative z-10"
                  >{strings.landing.searchButton}</span
                >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 relative z-10 transform group-hover:translate-x-1 group-hover:scale-110 transition-all duration-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </button>
            </div>
          </form>
        </div>

        <!-- RIGHT: Result panel (hidden initially, slides in) -->
        <div
          id="result-panel"
          class="w-full max-w-md transition-all duration-500 ease-in-out relative z-10 shrink-0"
          style="opacity: 0; transform: translateX(40px); pointer-events: none; width: 0; overflow: hidden; min-width: 0; max-width: 0;"
        >
          <!-- Not Found -->
          <div
            id="not-found-view"
            class="hidden text-center bg-white/80 backdrop-blur-md border border-red-100 rounded-3xl p-8 shadow-lg relative overflow-hidden"
          >
            <div
              class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-400 to-rose-400"
            >
            </div>
            <div
              class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4 border-4 border-red-100 shadow-sm"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                ></path>
              </svg>
            </div>
            <p class="text-slate-800 text-xl font-bold mb-2">
              {strings.landing.notFound}
            </p>
            <p class="text-slate-500 font-medium mb-6">
              {strings.landing.registerPrompt}
            </p>
            <div class="flex flex-row gap-3">
              <button
                type="button"
                id="not-found-back-btn"
                class="flex-1 bg-white border-2 border-slate-100 hover:border-slate-200 hover:bg-slate-50 text-slate-600 hover:text-slate-800 font-bold py-4 px-4 rounded-2xl transition-all cursor-pointer"
              >
                পুনরায় সার্চ
              </button>
              <button
                type="button"
                id="not-found-register-btn"
                class="flex-[1.2] bg-slate-900 hover:bg-slate-800 text-white font-bold py-4 px-4 rounded-2xl transition-all shadow-md hover:shadow-lg active:scale-[0.98] cursor-pointer"
              >
                অফিসটি নিবন্ধন করুন
              </button>
            </div>
          </div>

          <!-- Found -->
          <div
            id="found-view"
            class="hidden text-center bg-white/80 backdrop-blur-md border border-emerald-100 rounded-3xl p-8 shadow-lg relative overflow-hidden"
          >
            <div
              class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-400 to-teal-400"
            >
            </div>
            
            <div class="flex flex-row items-center justify-center gap-4 mb-8 bg-blue-50/50 p-4 rounded-2xl border border-blue-100/50">
              <div class="w-12 h-12 shrink-0 bg-white text-blue-600 rounded-full flex items-center justify-center shadow-sm border border-blue-100">
                <!-- Office Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <h3
                id="office-name"
                class="text-xl sm:text-2xl font-bold text-slate-800 line-clamp-2 text-left"
              >
                --
              </h3>
            </div>
            
            <p
              class="text-slate-500 font-semibold mb-6 text-lg"
            >
              এটা কি আপনার অফিস?
            </p>
            
            <div class="flex gap-4">
              <button
                id="confirm-btn"
                class="flex-1 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-400 hover:to-teal-400 text-white font-bold py-4 px-6 rounded-2xl transition-all shadow-md shadow-emerald-500/30 hover:shadow-emerald-500/40 active:scale-[0.98] flex items-center justify-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                হ্যাঁ
              </button>
              <button
                id="reject-btn"
                class="flex-1 bg-gradient-to-r from-red-500 to-rose-500 hover:from-red-400 hover:to-rose-400 text-white font-bold py-4 px-6 rounded-2xl transition-all shadow-md shadow-red-500/30 hover:shadow-red-500/40 active:scale-[0.98] flex items-center justify-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                না
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Registration Modal -->
  <div id="registration-modal" class="fixed inset-0 z-[60] hidden">
    <div
      class="absolute inset-0 bg-slate-900/40 backdrop-blur-md transition-opacity opacity-0"
      id="reg-modal-backdrop"
    >
    </div>
    <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-6">
      <div
        class="bg-white/90 backdrop-blur-2xl rounded-[2.5rem] shadow-2xl w-full max-w-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-300 flex flex-col max-h-[95vh] border border-white/50"
        id="reg-modal-content"
      >
        <div
          class="bg-gradient-to-r from-blue-700 to-indigo-700 px-8 py-6 text-white flex justify-between items-center shrink-0 relative overflow-hidden"
        >
          <div class="absolute inset-0 opacity-10 pointer-events-none"></div>
          <div class="relative z-10">
            <h2 class="text-2xl font-extrabold tracking-tight">
              {strings.registration.title}
            </h2>
            <p class="text-blue-100 text-sm font-medium mt-1 opacity-80">
              {strings.landing.title}
            </p>
          </div>
          <button
            type="button"
            id="close-reg-modal-btn"
            class="p-2 hover:bg-white/20 rounded-full transition-colors relative z-10"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="p-8 overflow-y-auto">
          <form id="register-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <label
                  for="reg_name"
                  class="block text-sm font-bold text-slate-700 mb-2 ml-1"
                >
                  {strings.registration.officeName}
                  <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="reg_name"
                  name="name"
                  placeholder={strings.registration.officeNamePlaceholder}
                  class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-2xl font-medium focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all"
                  required
                />
              </div>
              <div>
                <label
                  for="reg_budget_id"
                  class="block text-sm font-bold text-slate-700 mb-2 ml-1"
                >
                  {strings.registration.budgetId}
                  <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="reg_budget_id"
                  name="budget_id"
                  placeholder={strings.registration.budgetIdPlaceholder}
                  class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-2xl font-medium focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all"
                  required
                />
              </div>
              <div>
                <label
                  for="department"
                  class="block text-sm font-bold text-slate-700 mb-2 ml-1"
                >
                  {strings.registration.department}
                  <span class="text-red-500">*</span>
                </label>
                <select
                  id="department"
                  name="department"
                  class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-2xl font-medium focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all appearance-none cursor-pointer"
                  required
                >
                  <option value="" disabled selected
                    >{strings.registration.departmentPlaceholder}</option
                  >
                </select>
              </div>
              <div>
                <label
                  for="parent_office"
                  class="block text-sm font-bold text-slate-700 mb-2 ml-1"
                >
                  {strings.registration.parentOffice}
                </label>
                <select
                  id="parent_office"
                  name="parent_office"
                  class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-2xl font-medium focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                  disabled
                >
                  <option value="" selected
                    >{strings.registration.parentOfficePlaceholder}</option
                  >
                </select>
              </div>
              <div>
                <label
                  for="office_type"
                  class="block text-sm font-bold text-slate-700 mb-2 ml-1"
                >
                  {strings.registration.officeType}
                  <span class="text-red-500">*</span>
                </label>
                <select
                  id="office_type"
                  name="office_type"
                  class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-2xl font-medium focus:outline-none focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                  required
                  disabled
                >
                  <option value="" disabled selected
                    >{strings.registration.officeTypePlaceholder}</option
                  >
                </select>
              </div>
            </div>
            <div class="pt-6">
              <button
                type="button"
                id="preview-btn"
                class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold text-lg py-4 px-6 rounded-2xl transition-all shadow-lg hover:shadow-xl active:scale-[0.98]"
              >
                {strings.registration.saveButton}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Preview Modal -->
  <div id="preview-modal" class="fixed inset-0 z-[70] hidden">
    <div
      class="absolute inset-0 bg-slate-900/60 backdrop-blur-md transition-opacity opacity-0"
      id="preview-backdrop"
    >
    </div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div
        class="bg-white rounded-[2.5rem] shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 opacity-0 transition-all duration-300 flex flex-col max-h-[90vh]"
        id="preview-modal-content"
      >
        <div
          class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50/50"
        >
          <h3 class="text-2xl font-extrabold text-slate-800 tracking-tight">
            {strings.registration.previewTitle}
          </h3>
          <button
            type="button"
            id="close-preview-btn"
            class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-200/50 rounded-full transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="p-8 overflow-y-auto">
          <p
            class="text-sm font-medium text-slate-500 mb-8 bg-blue-50 text-blue-700 p-4 rounded-xl border border-blue-100"
          >
            {strings.registration.previewPrompt}
          </p>
          <div class="space-y-6">
            <div class="flex flex-col">
              <span
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1"
                >{strings.registration.officeName}</span
              >
              <span id="preview-name" class="text-xl font-bold text-slate-800"
              ></span>
            </div>
            <div class="flex flex-col">
              <span
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1"
                >{strings.registration.budgetId}</span
              >
              <span
                id="preview-budget-id"
                class="text-xl font-bold text-slate-800"></span>
            </div>
            <div class="flex flex-col">
              <span
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1"
                >{strings.registration.department}</span
              >
              <span
                id="preview-department"
                class="text-xl font-bold text-slate-800"></span>
            </div>
            <div class="flex flex-col">
              <span
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1"
                >{strings.registration.parentOffice}</span
              >
              <span id="preview-parent" class="text-xl font-bold text-slate-800"
              ></span>
            </div>
            <div class="flex flex-col">
              <span
                class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1"
                >{strings.registration.officeType}</span
              >
              <span id="preview-type" class="text-xl font-bold text-slate-800"
              ></span>
            </div>
          </div>
        </div>
        <div
          class="p-8 border-t border-slate-100 flex gap-4 bg-slate-50/50 mt-auto"
        >
          <button
            type="button"
            id="edit-btn"
            class="flex-[0.4] bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-slate-700 font-bold py-4 px-4 rounded-2xl transition-colors shadow-sm"
          >
            {strings.registration.editButton}
          </button>
          <button
            type="button"
            id="confirm-submit-btn"
            class="flex-[0.6] bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold py-4 px-4 rounded-2xl transition-all shadow-lg shadow-blue-500/30 active:scale-[0.98]"
          >
            {strings.confirm}
          </button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { supabase } from "../lib/supabase.js";
  import { toEnglishNumber } from "../lib/bangla.js";
  import { strings } from "../lib/strings.js";

  document.addEventListener("astro:page-load", async () => {
    if (
      window.location.pathname !== "/" &&
      window.location.pathname !== "/index.html"
    )
      return;

    const searchForm = document.getElementById("search-form");
    const budgetInput = document.getElementById(
      "budget_id",
    ) as HTMLInputElement;
    const searchBtn = document.getElementById(
      "search-btn",
    ) as HTMLButtonElement;
    const searchBtnText = document.getElementById("search-btn-text");

    const mainCard = document.getElementById("main-card");
    const searchPanel = document.getElementById("search-panel");
    const resultPanel = document.getElementById("result-panel");
    const notFoundView = document.getElementById("not-found-view");
    const foundView = document.getElementById("found-view");
    const officeNameEl = document.getElementById("office-name");

    const confirmBtn = document.getElementById("confirm-btn");
    const rejectBtn = document.getElementById("reject-btn");
    const notFoundRegisterBtn = document.getElementById(
      "not-found-register-btn",
    );
    const notFoundBackBtn = document.getElementById("not-found-back-btn");
    const openRegisterModalBtn = document.getElementById(
      "open-register-modal-btn",
    );

    const registrationModal = document.getElementById("registration-modal");
    const regModalBackdrop = document.getElementById("reg-modal-backdrop");
    const regModalContent = document.getElementById("reg-modal-content");
    const closeRegModalBtn = document.getElementById("close-reg-modal-btn");
    const regBudgetIdInput = document.getElementById(
      "reg_budget_id",
    ) as HTMLInputElement | null;

    const deptSelect = document.getElementById(
      "department",
    ) as HTMLSelectElement;
    const parentSelect = document.getElementById(
      "parent_office",
    ) as HTMLSelectElement;
    const typeSelect = document.getElementById(
      "office_type",
    ) as HTMLSelectElement;

    const regForm = document.getElementById("register-form") as HTMLFormElement;
    const previewBtn = document.getElementById("preview-btn");
    const previewModal = document.getElementById("preview-modal");
    const previewBackdrop = document.getElementById("preview-backdrop");
    const previewModalContent = document.getElementById(
      "preview-modal-content",
    );
    const closePreviewBtn = document.getElementById("close-preview-btn");
    const editBtn = document.getElementById("edit-btn");
    const regConfirmBtn = document.getElementById(
      "confirm-submit-btn",
    ) as HTMLButtonElement;

    let currentOfficeId: string | null = null;

    // =============================================
    // Split panel animation
    // =============================================
    const showResult = () => {
      if (!resultPanel || !searchPanel) return;

      searchPanel.style.display = "none";

      // Expand result panel
      resultPanel.style.width = "100%";
      resultPanel.style.maxWidth = "100%";
      resultPanel.style.minWidth = "100%";
      resultPanel.style.overflow = "visible";
      resultPanel.style.pointerEvents = "auto";

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          resultPanel.style.opacity = "1";
          resultPanel.style.transform = "translateX(0)";
        });
      });
    };

    const hideResult = () => {
      if (!resultPanel || !searchPanel) return;
      
      resultPanel.style.opacity = "0";
      resultPanel.style.transform = "translateX(40px)";
      resultPanel.style.pointerEvents = "none";

      setTimeout(() => {
        resultPanel.style.width = "0";
        resultPanel.style.maxWidth = "0";
        resultPanel.style.minWidth = "0";
        resultPanel.style.overflow = "hidden";

        searchPanel.style.display = "";
      }, 300);
    };

    // =============================================
    // Search
    // =============================================
    searchForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const rawInput = budgetInput.value.trim();
      if (!rawInput) return;

      const budgetId = toEnglishNumber(rawInput);
      const originalText = searchBtnText?.textContent ?? "";
      if (searchBtnText) searchBtnText.textContent = strings.loading;
      searchBtn.disabled = true;

      try {
        const { data, error } = await supabase
          .from("offices")
          .select("id, name")
          .eq("budget_id", budgetId)
          .maybeSingle();

        notFoundView?.classList.add("hidden");
        foundView?.classList.add("hidden");

        if (error || !data) {
          notFoundView?.classList.remove("hidden");
          currentOfficeId = null;
        } else {
          if (officeNameEl) officeNameEl.textContent = data.name;
          foundView?.classList.remove("hidden");
          currentOfficeId = data.id;
        }

        showResult();
        openRegisterModalBtn?.classList.add("hidden");
      } catch (err) {
        console.error("Search error", err);
        alert(strings.errors.general);
      } finally {
        if (searchBtnText) searchBtnText.textContent = originalText;
        searchBtn.disabled = false;
      }
    });

    confirmBtn?.addEventListener("click", () => {
      if (currentOfficeId) {
        sessionStorage.setItem("office_id", currentOfficeId);
        window.location.href = "/dashboard";
      }
    });

    rejectBtn?.addEventListener("click", () => {
      budgetInput.value = "";
      hideResult();
      openRegisterModalBtn?.classList.remove("hidden");
      budgetInput.focus();
    });

    notFoundBackBtn?.addEventListener("click", () => {
      budgetInput.value = "";
      hideResult();
      openRegisterModalBtn?.classList.remove("hidden");
      budgetInput.focus();
    });

    // =============================================
    // Registration modal
    // =============================================
    const openRegModal = () => {
      if (budgetInput && regBudgetIdInput && budgetInput.value.trim()) {
        regBudgetIdInput.value = budgetInput.value.trim();
      }
      registrationModal?.classList.remove("hidden");
      setTimeout(() => {
        regModalBackdrop?.classList.remove("opacity-0");
        regModalContent?.classList.remove("opacity-0", "scale-95");
      }, 10);
    };

    const closeRegModal = () => {
      regModalBackdrop?.classList.add("opacity-0");
      regModalContent?.classList.add("opacity-0", "scale-95");
      setTimeout(() => registrationModal?.classList.add("hidden"), 300);
    };

    openRegisterModalBtn?.addEventListener("click", openRegModal);
    notFoundRegisterBtn?.addEventListener("click", openRegModal);
    closeRegModalBtn?.addEventListener("click", closeRegModal);
    regModalBackdrop?.addEventListener("click", closeRegModal);

    // =============================================
    // Load departments
    // =============================================
    try {
      const { data: departments, error } = await supabase
        .from("departments")
        .select("id, name")
        .order("name");
      if (error) console.error("Supabase error:", error);
      if (departments && !error) {
        departments.forEach((dept) => {
          const option = document.createElement("option");
          option.value = dept.id;
          option.textContent = dept.name;
          deptSelect.appendChild(option);
        });
      }
    } catch (err) {
      console.error("Error loading departments", err);
    }

    deptSelect.addEventListener("change", async () => {
      const deptId = deptSelect.value;
      parentSelect.innerHTML = `<option value="" selected>${strings.registration.parentOfficePlaceholder}</option>`;
      typeSelect.innerHTML = `<option value="" disabled selected>${strings.registration.officeTypePlaceholder}</option>`;
      parentSelect.disabled = true;
      typeSelect.disabled = true;
      if (!deptId) return;

      try {
        const [{ data: parents }, { data: types }] = await Promise.all([
          supabase
            .from("parent_offices")
            .select("id, name")
            .eq("department_id", deptId)
            .order("name"),
          supabase
            .from("office_types")
            .select("id, name")
            .eq("department_id", deptId)
            .order("name"),
        ]);

        parents?.forEach((p) => {
          const o = document.createElement("option");
          o.value = p.id;
          o.textContent = p.name;
          parentSelect.appendChild(o);
        });
        types?.forEach((t) => {
          const o = document.createElement("option");
          o.value = t.id;
          o.textContent = t.name;
          typeSelect.appendChild(o);
        });

        parentSelect.disabled = false;
        typeSelect.disabled = false;
      } catch (err) {
        console.error("Error loading dependent fields", err);
      }
    });

    // =============================================
    // Preview modal
    // =============================================
    const openPreviewModal = () => {
      if (!regForm.checkValidity()) {
        regForm.reportValidity();
        return;
      }

      const name = (document.getElementById("reg_name") as HTMLInputElement)
        .value;
      const budgetId = (
        document.getElementById("reg_budget_id") as HTMLInputElement
      ).value;
      const deptName = deptSelect.options[deptSelect.selectedIndex].text;
      const parentName = parentSelect.value
        ? parentSelect.options[parentSelect.selectedIndex].text
        : strings.na;
      const typeName = typeSelect.options[typeSelect.selectedIndex].text;

      document.getElementById("preview-name")!.textContent = name;
      document.getElementById("preview-budget-id")!.textContent = budgetId;
      document.getElementById("preview-department")!.textContent = deptName;
      document.getElementById("preview-parent")!.textContent = parentName;
      document.getElementById("preview-type")!.textContent = typeName;

      previewModal?.classList.remove("hidden");
      setTimeout(() => {
        previewBackdrop?.classList.remove("opacity-0");
        previewModalContent?.classList.remove("opacity-0", "scale-95");
      }, 10);
    };

    const closePreviewModal = () => {
      previewBackdrop?.classList.add("opacity-0");
      previewModalContent?.classList.add("opacity-0", "scale-95");
      setTimeout(() => previewModal?.classList.add("hidden"), 300);
    };

    previewBtn?.addEventListener("click", openPreviewModal);
    closePreviewBtn?.addEventListener("click", closePreviewModal);
    editBtn?.addEventListener("click", closePreviewModal);
    previewBackdrop?.addEventListener("click", closePreviewModal);

    // =============================================
    // Registration submit
    // =============================================
    regConfirmBtn?.addEventListener("click", async () => {
      const name = (
        document.getElementById("reg_name") as HTMLInputElement
      ).value.trim();
      const rawBudgetId = (
        document.getElementById("reg_budget_id") as HTMLInputElement
      ).value.trim();
      const typeId = typeSelect.value;
      const parentId = parentSelect.value || null;
      const budgetId = toEnglishNumber(rawBudgetId);

      const oldText = regConfirmBtn.textContent;
      regConfirmBtn.textContent = strings.saving;
      regConfirmBtn.disabled = true;

      try {
        const { data: existing } = await supabase
          .from("offices")
          .select("id")
          .eq("budget_id", budgetId)
          .maybeSingle();
        if (existing) {
          alert(strings.registration.alreadyExists);
          closePreviewModal();
          return;
        }

        const { data, error } = await supabase
          .from("offices")
          .insert({
            name,
            budget_id: budgetId,
            office_type_id: parseInt(typeId),
            parent_office_id: parentId ? parseInt(parentId) : null,
          })
          .select()
          .single();

        if (error) throw error;
        if (data?.id) {
          sessionStorage.setItem("office_id", data.id);
          window.location.href = "/dashboard";
        }
      } catch (err) {
        console.error("Insert error", err);
        alert(strings.saveFailed);
      } finally {
        regConfirmBtn.textContent = oldText;
        regConfirmBtn.disabled = false;
      }
    });
  });
</script>
