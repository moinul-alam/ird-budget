---
import Base from '../layouts/Base.astro';
import { strings } from '../lib/strings.js';
---

<Base title={strings.landing.title}>
  <div class="min-h-[80vh] flex flex-col items-center justify-center relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute -z-10 w-[500px] h-[500px] bg-blue-300/30 rounded-full blur-3xl -top-20 -left-20 animate-pulse"></div>
    <div class="absolute -z-10 w-[400px] h-[400px] bg-indigo-300/20 rounded-full blur-3xl bottom-0 -right-10 animate-pulse" style="animation-delay: 2s;"></div>
    
    <div class="w-full max-w-lg bg-white/80 backdrop-blur-xl border border-white/40 shadow-2xl rounded-3xl p-8 sm:p-10 transition-all duration-500 hover:shadow-blue-900/10 hover:-translate-y-1">
      
      <div class="text-center mb-10">
        <div class="w-20 h-20 bg-gradient-to-tr from-blue-600 to-indigo-600 rounded-2xl mx-auto flex items-center justify-center shadow-lg shadow-blue-500/30 mb-6 rotate-3 hover:rotate-6 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-700 to-indigo-700 mb-2">
          {strings.landing.title}
        </h1>
        <p class="text-slate-500 font-medium">{strings.landing.subtitle}</p>
      </div>

      <form id="search-form" class="space-y-6">
        <div>
          <label for="budget_id" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.landing.enterBudgetId}
          </label>
          <div class="relative">
            <input 
              type="text" 
              id="budget_id" 
              name="budget_id" 
              placeholder={strings.landing.budgetIdPlaceholder}
              class="w-full px-5 py-4 bg-slate-50/50 border border-slate-200 rounded-xl text-lg font-medium text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 focus:bg-white transition-all shadow-sm"
              required
            />
            <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>
        </div>
        
        <button 
          type="submit" 
          id="search-btn"
          class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold text-lg py-4 px-6 rounded-xl shadow-lg shadow-blue-500/30 transition-all hover:shadow-blue-600/40 active:scale-[0.98] flex justify-center items-center gap-2 group"
        >
          <span>{strings.landing.searchButton}</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </form>

      <!-- Feedback Area -->
      <div id="feedback-area" class="mt-8 hidden opacity-0 transition-opacity duration-300">
        
        <!-- Not Found View -->
        <div id="not-found-view" class="hidden text-center bg-red-50/50 border border-red-100 rounded-2xl p-6">
          <div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <p class="text-slate-700 font-medium mb-1">{strings.landing.notFound}</p>
          <p class="text-slate-500 text-sm mb-5">{strings.landing.registerPrompt}</p>
          <a 
            href="/register" 
            class="inline-block w-full bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 font-semibold py-3 px-6 rounded-xl transition-all shadow-sm"
          >
            {strings.landing.registerButton}
          </a>
        </div>

        <!-- Found View -->
        <div id="found-view" class="hidden text-center bg-emerald-50/50 border border-emerald-100 rounded-2xl p-6">
          <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <p class="text-slate-500 text-sm font-medium mb-1">{strings.landing.foundOffice}</p>
          <h3 id="office-name" class="text-xl font-bold text-slate-800 mb-5">--</h3>
          
          <div class="flex flex-col gap-3">
            <button 
              id="confirm-btn"
              class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-6 rounded-xl transition-all shadow-sm shadow-emerald-200 active:scale-[0.98]"
            >
              {strings.landing.confirmOffice}
            </button>
            <button 
              id="reject-btn"
              class="w-full bg-white border border-slate-200 hover:bg-slate-50 text-slate-500 hover:text-slate-700 font-semibold py-3 px-6 rounded-xl transition-all"
            >
              {strings.landing.wrongOffice}
            </button>
          </div>
        </div>

      </div>
    </div>
    
    <div class="mt-12 text-center">
      <a href="/admin" class="text-sm font-medium text-slate-400 hover:text-blue-600 transition-colors flex items-center gap-1 justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        {strings.landing.adminLogin}
      </a>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '../lib/supabase.js';
  import { toEnglishNumber } from '../lib/bangla.js';
  import { strings } from '../lib/strings.js';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('search-form');
    const budgetInput = document.getElementById('budget_id') as HTMLInputElement;
    const searchBtn = document.getElementById('search-btn');
    const searchBtnSpan = searchBtn?.querySelector('span');
    
    const feedbackArea = document.getElementById('feedback-area');
    const notFoundView = document.getElementById('not-found-view');
    const foundView = document.getElementById('found-view');
    const officeNameEl = document.getElementById('office-name');
    
    const confirmBtn = document.getElementById('confirm-btn');
    const rejectBtn = document.getElementById('reject-btn');

    let currentOfficeId = null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const rawInput = budgetInput.value.trim();
      if (!rawInput) return;
      
      const budgetId = toEnglishNumber(rawInput);

      // Loading state
      const originalText = searchBtnSpan ? searchBtnSpan.textContent : '';
      if (searchBtnSpan) searchBtnSpan.textContent = strings.loading;
      if (searchBtn) (searchBtn as HTMLButtonElement).disabled = true;
      searchBtn?.classList.add('opacity-75', 'cursor-not-allowed');

      try {
        const { data, error } = await supabase
          .from('offices')
          .select('id, name')
          .eq('budget_id', budgetId)
          .maybeSingle();

        // Reset feedback area
        feedbackArea?.classList.remove('hidden');
        setTimeout(() => feedbackArea?.classList.remove('opacity-0'), 10);
        notFoundView?.classList.add('hidden');
        foundView?.classList.add('hidden');

        if (error || !data) {
          notFoundView?.classList.remove('hidden');
          currentOfficeId = null;
        } else {
          if (officeNameEl) officeNameEl.textContent = data.name;
          foundView?.classList.remove('hidden');
          currentOfficeId = data.id;
        }
      } catch (err) {
        console.error('Search error', err);
        alert(strings.errors.general);
      } finally {
        // Reset loading state
        if (searchBtnSpan && originalText) searchBtnSpan.textContent = originalText;
        if (searchBtn) (searchBtn as HTMLButtonElement).disabled = false;
        searchBtn?.classList.remove('opacity-75', 'cursor-not-allowed');
      }
    });

    confirmBtn?.addEventListener('click', () => {
      if (currentOfficeId) {
        sessionStorage.setItem('office_id', currentOfficeId);
        window.location.href = '/dashboard';
      }
    });

    rejectBtn?.addEventListener('click', () => {
      budgetInput.value = '';
      feedbackArea?.classList.add('opacity-0');
      setTimeout(() => {
        feedbackArea?.classList.add('hidden');
        notFoundView?.classList.add('hidden');
        foundView?.classList.add('hidden');
      }, 300);
      budgetInput.focus();
    });
  });
</script>
