---
import Base from '../layouts/Base.astro';
import { strings } from '../lib/strings.js';
import { toBanglaNumber } from '../lib/bangla.js';

interface FormType {
  id: number;
  title: string;
  short: string;
  hidden?: boolean;
}

// Pre-define the 10 forms to loop over in UI
const forms: FormType[] = [
  { id: 1, ...strings.forms.form1 },
  { id: 2, ...strings.forms.form2 },
  { id: 3, ...strings.forms.form3 },
  { id: 4, ...strings.forms.form4 },
  { id: 5, ...strings.forms.form5 },
  { id: 6, ...strings.forms.form6 },
  { id: 7, ...strings.forms.form7 },
  { id: 8, ...strings.forms.form8 },
  { id: 9, ...strings.forms.form9 },
  { id: 10, ...strings.forms.form10 },
];
const visibleForms = forms.filter(f => !f.hidden);
---

<Base title={strings.dashboard.title}>
  <!-- Top Navbar -->
  <div slot="full-width-header" class="w-full bg-white shadow-sm border-b border-slate-200">
    <div class="container mx-auto px-4 py-4 max-w-5xl flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <h1 id="nav-office-name" class="text-xl font-bold text-slate-800 inline">বাজেট ব্যবস্থাপনা</h1>
          <span id="nav-office-budget-id" class="text-sm text-slate-500 ml-2"></span>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <a href="/office/profile" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors bg-slate-50 text-slate-600 hover:bg-slate-100 border border-slate-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          অফিস প্রোফাইল
        </a>
        
        <button id="logout-btn" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors bg-red-50 text-red-600 hover:bg-red-100 border border-red-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3" />
          </svg>
          লগ আউট
        </button>
      </div>
    </div>
  </div>
  
  <!-- Loading State -->
  <div id="loading-state" class="min-h-[60vh] flex flex-col items-center justify-center">
    <div class="w-16 h-16 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin mb-4"></div>
    <p class="text-slate-500 font-medium">{strings.loading}</p>
  </div>

  <!-- Dashboard Content (hidden until loaded) -->
  <div id="dashboard-content" class="hidden opacity-0 transition-opacity duration-500 py-6">
    
    <!-- Header Section -->
    <div class="bg-gradient-to-r from-blue-700 to-indigo-800 rounded-3xl p-6 mb-8 text-white shadow-xl shadow-blue-900/10 relative overflow-hidden">
      <!-- Decorative rings -->
      <div class="absolute -right-20 -top-20 w-64 h-64 border-[30px] border-white/10 rounded-full blur-sm"></div>
      <div class="absolute -right-10 -bottom-20 w-48 h-48 border-[20px] border-white/5 rounded-full blur-sm"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <!-- Left: Cycle Info -->
        <div class="flex-1">
          <h3 class="text-blue-100 text-sm font-semibold mb-1 uppercase tracking-wider">{strings.dashboard.currentCycle}</h3>
          
          <!-- Cycle Selection UI -->
          <div id="cycle-selection-area" class="relative mb-3">
            <div id="cycle-info" class="text-xl font-bold">--</div>
            
            <div id="cycle-dropdown-wrapper" class="hidden">
              <select id="cycle-select" class="w-full bg-white/20 border border-white/30 text-white rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-white/50 appearance-none cursor-pointer font-medium text-lg">
                <option value="" disabled selected>{strings.cycle.selectCycle}</option>
              </select>
              <div class="absolute inset-y-0 right-3 flex items-center pointer-events-none text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
          </div>
          
          <div class="flex items-center gap-2">
            <span id="submission-status-label" class="text-sm text-blue-100">{strings.dashboard.statusDraft}</span>
            <div id="submission-status-indicator" class="w-3 h-3 bg-amber-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(251,191,36,0.8)]"></div>
          </div>
        </div>
        
        <!-- Right: Budget Amount -->
        <div id="total-budget-row" class="md:w-auto w-full bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 text-center shadow-inner">
          <h3 class="text-blue-200 text-xs font-semibold uppercase tracking-wider mb-1">মোট বাজেট</h3>
          <div id="total-budget-amount" class="text-3xl md:text-4xl font-bold text-white tracking-wide">--</div>
        </div>
      </div>
    </div>

    <!-- Forms Grid -->
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-xl font-bold text-slate-800">{strings.dashboard.formProgress}</h2>
      <span class="text-sm font-semibold text-slate-500 bg-slate-200 px-3 py-1 rounded-full">
        <span id="forms-completed-count">০</span> / {toBanglaNumber(visibleForms.length)} {strings.dashboard.progressLabel}
      </span>
    </div>

    <!-- Forms Container (starts visually disabled) -->
    <div id="forms-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10 opacity-50 pointer-events-none transition-all duration-300">
      {visibleForms.map((form) => (
        <div class="form-card group bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-blue-900/5 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden cursor-pointer" data-form-id={form.id}>
          
          <!-- Hover effect background -->
          <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          
          <div class="relative z-10 flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
              <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-lg group-hover:bg-blue-600 group-hover:text-white transition-colors">
                {toBanglaNumber(form.id)}
              </div>
              <span id={`status-badge-${form.id}`} class="px-2.5 py-1 bg-slate-100 text-slate-500 text-xs font-semibold rounded-lg border border-slate-200 transition-colors">
                {strings.dashboard.formNotStarted}
              </span>
            </div>
            
            <h3 class="font-bold text-lg text-slate-800 mb-1 leading-tight group-hover:text-blue-700 transition-colors">
              {form.title}
            </h3>
            <p class="text-sm text-slate-500 mt-auto pt-4">{form.short}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Action Bar -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col sm:flex-row gap-4 justify-between items-center shadow-sm">
      <a href="/office/budget-sheet" id="view-budget-btn" class="w-full sm:w-auto px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition-colors flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {strings.dashboard.viewBudgetSheet}
      </a>

      <button id="submit-budget-btn" class="hidden w-full sm:w-auto px-8 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-xl transition-colors shadow-lg shadow-emerald-500/30 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {strings.dashboard.submitBudget}
      </button>

      <button id="modify-budget-btn" class="hidden w-full sm:w-auto px-8 py-3 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl transition-colors shadow-lg shadow-amber-500/30 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        বাজেট সংশোধন করুন
      </button>
    </div>

  </div>

  <!-- Status Update Modal -->
  <div id="status-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity opacity-0" id="status-modal-backdrop"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform scale-95 opacity-0 transition-all duration-300 flex flex-col" id="status-modal-content">
        <div class="p-6 text-center">
          <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">{strings.cycle.alreadySubmitted}</h3>
          <p class="text-slate-500">{strings.cycle.updatePrompt}</p>
        </div>
        <div class="p-6 border-t border-slate-100 flex gap-4 bg-slate-50">
          <button type="button" id="status-cancel-btn" class="flex-1 bg-white border border-slate-300 hover:bg-slate-50 text-slate-700 font-semibold py-3 px-4 rounded-xl transition-colors">
            {strings.cycle.cancelButton}
          </button>
          <button type="button" id="status-update-btn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-md shadow-blue-500/20 active:scale-[0.98]">
            {strings.cycle.updateButton}
          </button>
        </div>
      </div>
    </div>
  </div>

</Base>

<script>
  import { supabase } from '../lib/supabase.js';
  import { toBanglaNumber, toBanglaFiscalYear, toBanglaBudgetType, toBanglaCurrency } from '../lib/bangla.js';
  import { strings } from '../lib/strings.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/dashboard')) return;
    const officeId = sessionStorage.getItem('office_id');
    
    // Redirect if no session
    if (!officeId) {
      window.location.href = '/';
      return;
    }

    const loadingState = document.getElementById('loading-state');
    const dashboardContent = document.getElementById('dashboard-content');
    const officeNameEl = document.getElementById('office-name');
    const officeBudgetIdEl = document.getElementById('office-budget-id');
    
    // Cycle Elements
    const cycleInfoEl = document.getElementById('cycle-info');
    const cycleDropdownWrapper = document.getElementById('cycle-dropdown-wrapper');
    const cycleSelect = document.getElementById('cycle-select') as HTMLSelectElement;
    
    // Submission Elements
    const formsContainer = document.getElementById('forms-container');
    const statusLabel = document.getElementById('submission-status-label');
    const statusIndicator = document.getElementById('submission-status-indicator');
    
    // Modal Elements
    const modal = document.getElementById('status-modal');
    const backdrop = document.getElementById('status-modal-backdrop');
    const modalContent = document.getElementById('status-modal-content');
    const cancelBtn = document.getElementById('status-cancel-btn');
    const updateBtn = document.getElementById('status-update-btn');

    const submitBudgetBtn = document.getElementById('submit-budget-btn');
    const modifyBudgetBtn = document.getElementById('modify-budget-btn');
    const totalBudgetRow = document.getElementById('total-budget-row');
    const totalBudgetAmount = document.getElementById('total-budget-amount');

    let currentSubmissionId: number | null = null;
    let selectedCycleId: string | null = null;
    let existingSubmissionStatus: string | null = null;

    // Helper: format cycle text
    const formatCycleText = (cycle: any) => {
      const fy = toBanglaFiscalYear(cycle.fiscal_year);
      const bt = toBanglaBudgetType(cycle.budget_type);
      return `${fy} - ${bt}`;
    };

    // Helper: handle submission status UI
    const updateStatusUI = (status: string) => {
      if (!statusLabel || !statusIndicator) return;
      
      statusIndicator.className = 'w-3 h-3 rounded-full shadow-lg';
      
      if (status === 'draft') {
        statusLabel.textContent = strings.dashboard.statusDraft;
        statusIndicator.classList.add('bg-amber-400', 'animate-pulse', 'shadow-amber-400/50');
      } else if (status === 'submitted') {
        statusLabel.textContent = strings.dashboard.statusSubmitted;
        statusIndicator.classList.add('bg-emerald-500', 'shadow-emerald-500/50');
      } else if (status === 'needs_resubmit') {
        statusLabel.textContent = strings.dashboard.statusNeedsResubmit;
        statusIndicator.classList.add('bg-rose-500', 'animate-pulse', 'shadow-rose-500/50');
      }
    };

    // Helper: unlock forms
    const unlockForms = () => {
      if (formsContainer) {
        formsContainer.classList.remove('opacity-50', 'pointer-events-none');
        
        // Add click listeners to navigate
        const cards = formsContainer.querySelectorAll('.form-card');
        cards.forEach(card => {
          card.addEventListener('click', () => {
            const formId = card.getAttribute('data-form-id');
            if (formId) {
              window.location.href = `/office/form-${formId}`;
            }
          });
        });
      }

      // Show submit button, hide modify
      submitBudgetBtn?.classList.remove('hidden');
      modifyBudgetBtn?.classList.add('hidden');
    };

    // Helper: show submitted state (forms locked, modify button visible)
    const showSubmittedState = () => {
      submitBudgetBtn?.classList.add('hidden');
      modifyBudgetBtn?.classList.remove('hidden');
    };

    // Helper: process selected cycle
    const processCycle = async (cId: string) => {
      selectedCycleId = cId;
      sessionStorage.setItem('cycle_id', cId);

      try {
        // Query submissions
        const { data: sub, error } = await supabase
          .from('submissions')
          .select('id, status')
          .eq('office_id', officeId)
          .eq('cycle_id', cId)
          .maybeSingle();

        if (error) throw error;

        if (!sub) {
          // CREATE new submission
          const { data: newSub, error: insertErr } = await supabase
            .from('submissions')
            .insert({
              office_id: parseInt(officeId),
              cycle_id: parseInt(cId),
              status: 'draft'
            })
            .select('id, status')
            .single();

          if (insertErr) throw insertErr;
          
          currentSubmissionId = newSub.id;
          sessionStorage.setItem('submission_id', String(newSub.id));
          updateStatusUI(newSub.status);
          unlockForms();
          updateFormProgress(newSub.id);

        } else {
          // Exists
          currentSubmissionId = sub.id;
          sessionStorage.setItem('submission_id', String(sub.id));
          existingSubmissionStatus = sub.status;
          updateStatusUI(sub.status);

          if (sub.status === 'draft' || sub.status === 'needs_resubmit') {
            unlockForms();
          } else if (sub.status === 'submitted') {
            showSubmittedState();
          }
          updateFormProgress(sub.id);
        }

        // Fetch and display total budget
        if (currentSubmissionId) {
          await fetchTotalBudget(currentSubmissionId);
        }

      } catch (err) {
        console.error('Error processing cycle', err);
        alert(strings.errors.general);
      }
    };

    // Helper: check progress of forms
    const updateFormProgress = async (subId: number) => {
      let completedCount = 0;
      
      const setCompleted = (formId: number) => {
        completedCount++;
        const badge = document.getElementById(`status-badge-${formId}`);
        if (badge) {
          badge.textContent = 'তথ্য এন্টি করা হয়েছে';
          badge.className = 'px-2.5 py-1 bg-emerald-50 text-emerald-600 text-xs font-semibold rounded-lg border border-emerald-200 transition-colors';
        }
      };

      try {
        // For form_basic, check if there's actually meaningful data (auto-save creates empty rows)
        const [
          { data: d1 }, { count: c2 }, { count: c3 }, { count: c4 }, { count: c5 },
          { count: c6 }, { count: c7 }, { count: c8 }, { count: c9 }, { count: c10 }
        ] = await Promise.all([
          supabase.from('form_basic').select('head_of_office, designation, phone, email, address').eq('submission_id', subId).maybeSingle(),
          supabase.from('form_staff').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_allowances').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_leave').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_vehicles').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_vehicle_rent').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_it_equipment').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_utility').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_house_rent').select('*', { count: 'exact', head: true }).eq('submission_id', subId),
          supabase.from('form_return_info').select('*', { count: 'exact', head: true }).eq('submission_id', subId)
        ]);

        // Debug: log all counts
        console.log('Form progress:', { d1, c2, c3, c4, c5, c6, c7, c8, c9, c10 });

        // Form 1: check actual field content, not just row existence
        const hasForm1Data = d1 && (d1.head_of_office || d1.designation || d1.phone || d1.email || d1.address);
        if (hasForm1Data) setCompleted(1);
        if (c2 && c2 > 0) setCompleted(2);
        if (c3 && c3 > 0) setCompleted(3);
        if (c4 && c4 > 0) setCompleted(4);
        if (c5 && c5 > 0) setCompleted(5);
        if (c6 && c6 > 0) setCompleted(6);
        if (c7 && c7 > 0) setCompleted(7);
        if (c8 && c8 > 0) setCompleted(8);
        if (c9 && c9 > 0) setCompleted(9);
        if (c10 && c10 > 0) setCompleted(10);

        const completedEl = document.getElementById('forms-completed-count');
        if (completedEl) completedEl.textContent = toBanglaNumber(completedCount);
      } catch (err) {
        console.error('Error fetching progress', err);
      }
    };

    // Helper: fetch and display total budget
    const fetchTotalBudget = async (subId: number) => {
        try {
            const { data: rows } = await supabase
                .from('budget_sheet')
                .select('auto_value, manual_value, code_id, expense_codes(code)')
                .eq('submission_id', subId);

            if (rows && rows.length > 0) {
                const { codeFormulas } = await import('../lib/formulas.js');
                let total = 0;
                rows.forEach((row: any) => {
                    const code = row.expense_codes?.code as keyof typeof codeFormulas;
                    const isAuto = codeFormulas[code] !== undefined;
                    if (isAuto) {
                        total += parseFloat(row.auto_value) || 0;
                    } else {
                        total += parseFloat(row.manual_value) || 0;
                    }
                });
                if (totalBudgetRow) totalBudgetRow.classList.remove('hidden');
                if (totalBudgetAmount) totalBudgetAmount.textContent = toBanglaCurrency(total);
            }
        } catch (err) {
            console.error('Error fetching total budget', err);
        }
    };

    // Init Logic
    try {
      // Fetch office info
      const { data: office, error: officeError } = await supabase
        .from('offices')
        .select('name, budget_id')
        .eq('id', officeId)
        .single();

      if (officeError || !office) throw officeError;

      if (officeNameEl) officeNameEl.textContent = office.name;
      if (officeBudgetIdEl) officeBudgetIdEl.textContent = toBanglaNumber(office.budget_id);
      const navOfficeNameEl = document.getElementById('nav-office-name');
      const navOfficeBudgetIdEl = document.getElementById('nav-office-budget-id');
      if (navOfficeNameEl) navOfficeNameEl.textContent = office.name;
      if (navOfficeBudgetIdEl) navOfficeBudgetIdEl.textContent = `(${toBanglaNumber(office.budget_id)})`;

      // Fetch all open cycles
      const { data: cycles, error: cyclesError } = await supabase
        .from('cycles')
        .select('id, fiscal_year, budget_type')
        .eq('status', 'open')
        .order('id', { ascending: false });

      if (cyclesError) throw cyclesError;

      if (!cycles || cycles.length === 0) {
        // No cycles open
        if (cycleInfoEl) {
          cycleInfoEl.innerHTML = `<span class="text-rose-300 block text-sm mb-1">${strings.cycle.noCycleOpen}</span><span class="text-blue-100 text-xs font-normal">${strings.cycle.noCycleContact}</span>`;
        }
      } else if (cycles.length === 1) {
        // Exactly 1 cycle
        const c = cycles[0];
        if (cycleInfoEl) {
          const fy = toBanglaFiscalYear(c.fiscal_year);
          const bt = toBanglaBudgetType(c.budget_type);
          cycleInfoEl.innerHTML = `${fy} <br/><span class="text-blue-200 font-medium text-lg">${bt}</span>`;
        }
        await processCycle(c.id);
      } else {
        // Multiple cycles - Show Dropdown
        if (cycleInfoEl) cycleInfoEl.classList.add('hidden');
        if (cycleDropdownWrapper) cycleDropdownWrapper.classList.remove('hidden');
        
        cycles.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = formatCycleText(c);
          opt.className = "text-slate-800";
          cycleSelect.appendChild(opt);
        });

        cycleSelect.addEventListener('change', async (e) => {
          const val = (e.target as HTMLSelectElement).value;
          if (val) {
            cycleSelect.disabled = true; // Prevent multiple clicks while processing
            await processCycle(val);
            cycleSelect.disabled = false;
          }
        });
      }

      // Show content
      loadingState?.classList.add('hidden');
      dashboardContent?.classList.remove('hidden');
      setTimeout(() => dashboardContent?.classList.remove('opacity-0'), 50);

    } catch (err) {
      console.error('Failed to load dashboard', err);
      alert(strings.errors.loadFailed);
      sessionStorage.removeItem('office_id');
      window.location.href = '/';
    }

    // Modal Actions
    const closeModal = () => {
      backdrop?.classList.add('opacity-0');
      modalContent?.classList.add('opacity-0', 'scale-95');
      setTimeout(() => modal?.classList.add('hidden'), 300);
    };

    cancelBtn?.addEventListener('click', closeModal); // Forms remain locked

    // Submit Budget from dashboard
    submitBudgetBtn?.addEventListener('click', () => {
      window.location.href = '/office/budget-sheet';
    });

    // Log out button
    const logoutBtn = document.getElementById('logout-btn');
    logoutBtn?.addEventListener('click', () => {
      sessionStorage.removeItem('office_id');
      sessionStorage.removeItem('cycle_id');
      sessionStorage.removeItem('submission_id');
      window.location.href = '/';
    });
    
    // Modify Budget - unlock everything
    modifyBudgetBtn?.addEventListener('click', async () => {
      if (!currentSubmissionId) return;

      const confirmed = confirm('আপনি কি বাজেট সংশোধন করতে চান? সকল ফর্ম সম্পাদনাযোগ্য হবে।');
      if (!confirmed) return;

      (modifyBudgetBtn as HTMLButtonElement).disabled = true;
      modifyBudgetBtn.textContent = 'সংশোধন হচ্ছে...';

      try {
        const { error } = await supabase
          .from('submissions')
          .update({ status: 'draft' })
          .eq('id', currentSubmissionId);

        if (error) throw error;

        updateStatusUI('draft');
        unlockForms();
      } catch (err) {
        console.error('Modify error', err);
        alert('সংশোধন করতে সমস্যা হয়েছে।');
      } finally {
        (modifyBudgetBtn as HTMLButtonElement).disabled = false;
        modifyBudgetBtn.textContent = 'বাজেট সংশোধন করুন';
      }
    });
    
    updateBtn?.addEventListener('click', async () => {
      if (!currentSubmissionId) return;
      
      const originalText = updateBtn.textContent;
      updateBtn.textContent = strings.saving;
      (updateBtn as HTMLButtonElement).disabled = true;

      try {
        const { error } = await supabase
          .from('submissions')
          .update({ status: 'needs_resubmit' })
          .eq('id', currentSubmissionId);

        if (error) throw error;

        updateStatusUI('needs_resubmit');
        unlockForms();
        closeModal();

      } catch (err) {
        console.error('Update status error', err);
        alert(strings.saveFailed);
      } finally {
        updateBtn.textContent = originalText;
        (updateBtn as HTMLButtonElement).disabled = false;
      }
    });

  });
</script>
