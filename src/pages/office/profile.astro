---
import Base from '../../layouts/Base.astro';
import { strings } from '../../lib/strings.js';
---

<Base title="অফিস প্রোফাইল">
  <!-- Top Navbar -->
  <div slot="full-width-header" class="w-full bg-white shadow-sm border-b border-slate-200">
    <div class="container mx-auto px-4 py-3 max-w-5xl flex items-center justify-between mb-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <h1 id="nav-office-name" class="text-xl font-bold text-slate-800 inline">বাজেট ব্যবস্থাপনা</h1>
          <span id="nav-office-budget-id" class="text-sm text-slate-500 ml-2"></span>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <a href="/dashboard" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors bg-slate-50 text-slate-600 hover:bg-slate-100 border border-slate-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          ড্যাশবোর্ড
        </a>
        
        <button id="logout-btn" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors bg-red-50 text-red-600 hover:bg-red-100 border border-red-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3" />
          </svg>
          লগ আউট
        </button>
      </div>
    </div>
  </div>

  <div class="max-w-2xl mx-auto py-10">
    <div class="bg-white rounded-3xl shadow-xl shadow-blue-900/5 border border-slate-100 overflow-hidden">
      <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-6 text-white">
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="p-2 bg-white/20 hover:bg-white/30 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </a>
          <div>
            <h1 class="text-2xl font-bold">অফিস প্রোফাইল</h1>
            <p class="text-blue-100 text-sm mt-1">আপনার অফিসের তথ্য আপডেট করুন</p>
          </div>
        </div>
      </div>

      <div class="p-8">
        <form id="profile-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                অফিসের নাম <span class="text-red-500">*</span>
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="অফিসের নাম লিখুন"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
                required
              />
            </div>

            <div>
              <label for="budget_id" class="block text-sm font-semibold text-slate-700 mb-2">
                বাজেট আইডি <span class="text-red-500">*</span>
              </label>
              <input 
          type="text" 
          id="budget_id" 
          name="budget_id" 
          placeholder="বাজেট আইডি লিখুন"
          class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
        />
            </div>

            <div>
              <label for="department" class="block text-sm font-semibold text-slate-700 mb-2">
                বিভাগ <span class="text-red-500">*</span>
              </label>
              <select 
                id="department" 
                name="department" 
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all appearance-none cursor-pointer"
                required
                disabled
              >
                <option value="" disabled selected>বিভাগ নির্বাচন করুন</option>
              </select>
            </div>

            <div>
              <label for="parent_office" class="block text-sm font-semibold text-slate-700 mb-2">
                প্যারেন্ট অফিস
              </label>
              <select 
                id="parent_office" 
                name="parent_office" 
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all appearance-none cursor-pointer"
                disabled
              >
                <option value="" selected>প্যারেন্ট অফিস নির্বাচন করুন</option>
              </select>
            </div>

            <div>
              <label for="office_type" class="block text-sm font-semibold text-slate-700 mb-2">
                অফিসের ধরন <span class="text-red-500">*</span>
              </label>
              <select 
                id="office_type" 
                name="office_type" 
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all appearance-none cursor-pointer"
                required
                disabled
              >
                <option value="" disabled selected>অফিসের ধরন নির্বাচন করুন</option>
              </select>
            </div>
          </div>

          <div class="pt-4 flex gap-4">
            <button 
              type="button" 
              id="cancel-btn"
              class="flex-1 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-semibold py-3 px-4 rounded-xl transition-all"
            >
              বাতিল
            </button>
            <button 
              type="submit" 
              id="save-btn"
              class="flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-md shadow-blue-500/20 active:scale-[0.98]"
            >
              সংরক্ষণ করুন
            </button>
          </div>
        </form>

        <!-- Success Message -->
        <div id="success-message" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-green-800 font-medium">প্রোফাইল সফলভাবে আপডেট হয়েছে!</span>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '../../lib/supabase.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/profile')) return;
    
    const form = document.getElementById('profile-form') as HTMLFormElement;
    const nameInput = document.getElementById('name') as HTMLInputElement;
    const budgetIdInput = document.getElementById('budget_id') as HTMLInputElement;
    const deptSelect = document.getElementById('department') as HTMLSelectElement;
    const parentSelect = document.getElementById('parent_office') as HTMLSelectElement;
    const typeSelect = document.getElementById('office_type') as HTMLSelectElement;
    const cancelBtn = document.getElementById('cancel-btn');
    const saveBtn = document.getElementById('save-btn');
    const successMessage = document.getElementById('success-message');

    // Logout
    const handleLogout = () => {
      sessionStorage.removeItem('office_id');
      sessionStorage.removeItem('cycle_id');
      sessionStorage.removeItem('submission_id');
      window.location.href = '/';
    };

    const logoutBtn = document.getElementById('logout-btn');
    logoutBtn?.addEventListener('click', handleLogout);

    // Cancel button
    cancelBtn?.addEventListener('click', () => {
      window.location.href = '/dashboard';
    });

    // Load office data
    const officeId = sessionStorage.getItem('office_id');
    if (!officeId) {
      window.location.href = '/';
      return;
    }

    try {
      // Load departments first
      const { data: departments } = await supabase.from('departments').select('id, name').order('name');
      if (departments) {
        departments.forEach(dept => {
          const option = document.createElement('option');
          option.value = dept.id;
          option.textContent = dept.name;
          deptSelect.appendChild(option);
        });
      }

      // Get office data with all relations
      const { data: office, error } = await supabase
        .from('offices')
        .select(`
          id,
          name,
          budget_id,
          office_type_id,
          parent_office_id,
          office_types ( id, name, department_id ),
          parent_offices ( id, name ),
          departments: office_types ( department_id )
        `)
        .eq('id', officeId)
        .single();

      if (error) throw error;

      if (office) {
        nameInput.value = office.name;
        budgetIdInput.value = office.budget_id;
        const navOfficeNameEl = document.getElementById('nav-office-name');
        const navOfficeBudgetIdEl = document.getElementById('nav-office-budget-id');
        if (navOfficeNameEl) navOfficeNameEl.textContent = office.name;
        if (navOfficeBudgetIdEl) navOfficeBudgetIdEl.textContent = `(${toBanglaNumber(office.budget_id)})`;

        // Set department
        if (office.office_types?.department_id) {
          deptSelect.value = office.office_types.department_id;
          
          // Load parent offices
          const { data: parents } = await supabase
            .from('parent_offices')
            .select('id, name')
            .eq('department_id', office.office_types.department_id)
            .order('name');
            
          if (parents && parents.length > 0) {
            parentSelect.innerHTML = '<option value="" selected>প্যারেন্ট অফিস নির্বাচন করুন</option>';
            parents.forEach(p => {
              const option = document.createElement('option');
              option.value = p.id;
              option.textContent = p.name;
              if (office.parent_office_id === p.id) {
                option.selected = true;
              }
              parentSelect.appendChild(option);
            });
          }

          // Load office types
          const { data: types } = await supabase
            .from('office_types')
            .select('id, name')
            .eq('department_id', office.office_types.department_id)
            .order('name');
            
          if (types && types.length > 0) {
            typeSelect.innerHTML = '<option value="" disabled selected>অফিসের ধরন নির্বাচন করুন</option>';
            types.forEach(t => {
              const option = document.createElement('option');
              option.value = t.id;
              option.textContent = t.name;
              if (office.office_type_id === t.id) {
                option.selected = true;
              }
              typeSelect.appendChild(option);
            });
          }
        }
      }
    } catch (err) {
      console.error('Error loading profile', err);
    }

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const oldText = saveBtn.textContent;
      saveBtn.textContent = 'সংরক্ষণ হচ্ছে...';
      (saveBtn as HTMLButtonElement).disabled = true;
      
      try {
        const { error } = await supabase
          .from('offices')
          .update({ 
            name: nameInput.value, 
            budget_id: budgetIdInput.value 
          })
          .eq('id', officeId);

        if (error) throw error;

        successMessage?.classList.remove('hidden');
        
        setTimeout(() => {
          successMessage?.classList.add('hidden');
        }, 3000);
      } catch (err) {
        console.error('Error updating profile', err);
        alert('আপডেট করতে সমস্যা হয়েছে!');
      } finally {
        saveBtn.textContent = oldText;
        (saveBtn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>
