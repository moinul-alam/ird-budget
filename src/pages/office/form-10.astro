---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.form10.title} formId="Form 10" prevUrl="/office/form-9" nextUrl="/office/budget-sheet">
  
  <div class="p-8 md:p-10 space-y-8">
    
    <div class="mb-4">
      <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {strings.form10.title}
      </h2>
    </div>

    <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-6">
      
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form10.tinCount}</label>
        <input type="number" min="0" id="tin_count" placeholder={strings.form10.tinCountPlaceholder} class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
      </div>

      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form10.returnCount}</label>
        <input type="number" min="0" id="return_submitted_count" placeholder={strings.form10.returnCountPlaceholder} class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
      </div>

      <div class="p-4 bg-orange-50 rounded-xl border border-orange-100">
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm font-medium text-orange-800">{strings.form10.postalExpense}</span>
          <span id="postal-calc" class="font-bold text-orange-900">0</span>
        </div>
        <p class="text-xs text-orange-600/70">{strings.form10.postalNote} (<span id="postal-rate">0</span> টাকা/রিটার্ন)</p>
      </div>

    </div>

  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaCurrency, toBanglaNumber } from '../../lib/bangla.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-10')) return;
    // 1. Session Check
    const submissionId = sessionStorage.getItem('submission_id');
    if (!submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let existingId = null;
    let isLocked = false;
    let postalRate = 0;

    const tinCountInput = document.getElementById('tin_count') as HTMLInputElement;
    const returnCountInput = document.getElementById('return_submitted_count') as HTMLInputElement;
    
    const postalCalcEl = document.getElementById('postal-calc');
    const postalRateEl = document.getElementById('postal-rate');

    const updatePostalDisplay = () => {
      const count = parseInt(returnCountInput.value || '0', 10);
      const totalExpense = count * postalRate;
      if (postalCalcEl) postalCalcEl.textContent = toBanglaCurrency(totalExpense);
    };

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Logic (UPSERT)
    const saveData = async () => {
      if (isLocked) return;
      showSaving();

      const payload = {
        submission_id: parseInt(submissionId),
        tin_count: parseInt(tinCountInput.value || '0', 10),
        return_submitted_count: parseInt(returnCountInput.value || '0', 10)
      };

      try {
        if (existingId) {
          await supabase.from('form_return_info').update(payload).eq('id', existingId);
        } else {
          const { data } = await supabase.from('form_return_info').insert(payload).select().single();
          if (data) existingId = data.id;
        }
        showSaved();
      } catch (err) {
        console.error('Save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: formData }, { data: rateData }, { data: subData }] = await Promise.all([
        supabase.from('form_return_info').select('*').eq('submission_id', submissionId).maybeSingle(),
        supabase.from('rates').select('value').eq('key', 'postal_expense_rate').single(),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (rateData) {
        postalRate = parseFloat(rateData.value);
        if (postalRateEl) postalRateEl.textContent = toBanglaNumber(postalRate);
      }

      if (subData && subData.status === 'submitted') isLocked = true;

      if (formData) {
        existingId = formData.id;
        tinCountInput.value = formData.tin_count || '';
        returnCountInput.value = formData.return_submitted_count || '';
        updatePostalDisplay();
      }

      // Attach Event Listeners
      const inputs = document.querySelectorAll('.form-input');
      
      if (isLocked) {
        inputs.forEach(input => (input as HTMLInputElement).disabled = true);
      } else {
        let saveTimeout;
        inputs.forEach(input => {
          input.addEventListener('input', () => {
            if (input.id === 'return_submitted_count') updatePostalDisplay();
          });
          input.addEventListener('blur', () => {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveData, 500);
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 10:', err);
    }

    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', () => {
        // Trigger blur on active element to fire auto-save, or just trigger save
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Show saving if not already shown by blur
        const saveIndicator = document.getElementById('save-indicator');
        const saveSpinner = document.getElementById('save-spinner');
        const saveCheck = document.getElementById('save-check');
        const saveText = document.getElementById('save-text');
        
        if (saveIndicator) saveIndicator.classList.remove('opacity-0');
        if (saveSpinner) saveSpinner.classList.remove('hidden');
        if (saveCheck) saveCheck.classList.add('hidden');
        if (saveText) saveText.textContent = strings.saving || 'সংরক্ষণ করা হচ্ছে...';
        
        // Let auto-save handle the actual save, if nothing was active, nothing to save but visual feedback helps
      });
    }
  });
</script>
