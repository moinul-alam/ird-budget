---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.budgetSheet.title} formId="বাজেট শিট">
  
  <div class="p-8 md:p-10">
    <div class="mb-6 flex justify-between items-center">
      <div>
        <h2 class="text-xl font-bold text-slate-800 mb-2">{strings.budgetSheet.title}</h2>
        <p class="text-slate-500 text-sm">{strings.budgetSheet.autoNote}</p>
      </div>
      <button id="recalculate-btn" class="hidden px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-lg transition-colors flex items-center gap-2 text-sm border border-slate-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        {strings.budgetSheet.recalculateButton}
      </button>
    </div>

    <!-- Initialization Loading State -->
    <div id="init-loading" class="py-20 text-center">
      <svg class="animate-spin h-10 w-10 text-blue-600 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p id="loading-text" class="text-slate-500 font-medium animate-pulse">বাজেট শিট প্রস্তুত করা হচ্ছে...</p>
    </div>

    <!-- Data Table -->
    <div id="budget-container" class="hidden overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
      <div class="overflow-x-auto max-h-[70vh]">
        <table class="w-full text-left border-collapse relative">
          <thead class="sticky top-0 bg-slate-800 z-10 shadow-md">
            <tr>
              <th class="p-4 font-bold text-slate-100 border-b border-slate-700 w-24 text-center">{strings.budgetSheet.codeColumn}</th>
              <th class="p-4 font-bold text-slate-100 border-b border-slate-700 w-auto">{strings.budgetSheet.nameColumn}</th>
              <th id="budget-header-text" class="p-4 font-bold text-slate-100 border-b border-slate-700 w-1/4 text-right bg-indigo-900/40">বাজেট</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="budget-body">
            <!-- Dynamically populated -->
          </tbody>
          <tfoot class="sticky bottom-0 bg-slate-50 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] border-t-2 border-slate-300 z-10">
            <tr>
              <td colspan="2" class="p-5 font-bold text-slate-800 text-right text-lg">{strings.budgetSheet.totalRow}</td>
              <td id="grand-total-final" class="p-5 font-bold text-indigo-700 text-right text-xl font-mono">০</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <div slot="footer-action" id="footer-actions">
    <button id="final-submit-btn" class="hidden px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md shadow-blue-500/20 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      চূড়ান্ত দাখিল করুন
    </button>
    <a href="/dashboard" id="return-dashboard-btn" class="hidden px-8 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl transition-colors shadow-md shadow-emerald-500/20 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      ড্যাশবোর্ডে ফিরে যান
    </a>
  </div>

</FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaCurrency } from '../../lib/bangla.js';
  import { calculateAll, codeFormulas } from '../../lib/formulas.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/budget-sheet')) return;
    const submissionId = sessionStorage.getItem('submission_id');
    const cycleId = sessionStorage.getItem('cycle_id');
    if (!submissionId || !cycleId) {
      window.location.href = '/';
      return;
    }

    const initLoading = document.getElementById('init-loading');
    const loadingText = document.getElementById('loading-text');
    const budgetContainer = document.getElementById('budget-container');
    const tbody = document.getElementById('budget-body');
    const totalFinalEl = document.getElementById('grand-total-final');
    const recalculateBtn = document.getElementById('recalculate-btn');
    const finalSubmitBtn = document.getElementById('final-submit-btn');
    const returnDashboardBtn = document.getElementById('return-dashboard-btn');

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let isLocked = false;
    let budgetRows = [];

    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    const updateTotal = () => {
      let sumFinal = 0;

      budgetRows.forEach(row => {
        const isAuto = codeFormulas[row.expense_codes?.code] !== undefined;
        if (isAuto) {
            sumFinal += parseFloat(row.auto_value) || 0;
        } else {
            const manualInput = document.getElementById(`manual-${row.id}`) as HTMLInputElement;
            const currentManual = manualInput && manualInput.value ? parseInt(manualInput.value, 10) : (row.manual_value || 0);
            sumFinal += currentManual;
        }
      });

      if (totalFinalEl) totalFinalEl.textContent = toBanglaCurrency(sumFinal);
    };

    const saveRow = async (rowId, inputEl) => {
      if (isLocked) return;
      showSaving();

      const manualVal = inputEl.value ? parseInt(inputEl.value, 10) : null;

      try {
        await supabase.from('budget_sheet')
          .update({ manual_value: manualVal })
          .eq('id', rowId);
        
        // Update local state so updateTotal uses the new value
        const rowIndex = budgetRows.findIndex(r => r.id === parseInt(rowId));
        if (rowIndex > -1) {
            budgetRows[rowIndex].manual_value = manualVal;
        }

        updateTotal();
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    const renderTable = () => {
        if (!tbody) return;
        tbody.innerHTML = '';

        let currentParentCode = null;

        budgetRows.forEach((row, index) => {
            const pCode = row.expense_codes?.parent_code || null;
            const pTitle = row.expense_codes?.parent_title || '';

            // Grouping Header
            if (pCode && pCode !== currentParentCode) {
                const headerTr = document.createElement('tr');
                headerTr.className = 'bg-slate-200 border-b-2 border-slate-300 cursor-pointer hover:bg-slate-300 transition-colors group';
                headerTr.innerHTML = `
                    <td class="p-3 border-r border-slate-300 text-center">
                        <span class="inline-block px-2.5 py-1 bg-slate-800 text-white font-mono text-sm rounded-lg font-bold">${pCode}</span>
                    </td>
                    <td colspan="2" class="p-3 text-slate-800 font-bold">
                        <div class="flex items-center justify-between w-full">
                            <span>${pTitle}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform transition-transform duration-200 text-slate-500 group-hover:text-slate-800" id="icon-${pCode}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </div>
                    </td>
                `;
                
                headerTr.addEventListener('click', () => {
                    const children = document.querySelectorAll(`.child-of-${pCode}`);
                    const icon = document.getElementById(`icon-${pCode}`);
                    let isCollapsed = false;
                    
                    children.forEach(child => {
                        if (child.classList.contains('hidden')) {
                            child.classList.remove('hidden');
                            isCollapsed = false;
                        } else {
                            child.classList.add('hidden');
                            isCollapsed = true;
                        }
                    });
                    
                    if (isCollapsed) {
                        icon?.classList.add('-rotate-90');
                    } else {
                        icon?.classList.remove('-rotate-90');
                    }
                });

                tbody.appendChild(headerTr);
                currentParentCode = pCode;
            }

            const lockAttr = isLocked ? 'disabled' : '';
            const isEven = index % 2 === 0;
            const bgClass = isEven ? 'bg-white' : 'bg-slate-50';

            const codeName = row.expense_codes?.name || 'Unknown';
            const codeCode = row.expense_codes?.code || 'Unknown';
            const isAuto = codeFormulas[codeCode] !== undefined;
            
            const autoVal = parseFloat(row.auto_value) || 0;
            const manualVal = row.manual_value !== null ? row.manual_value : '';

            const tr = document.createElement('tr');
            // Add child-of-${pCode} class for toggle logic
            tr.className = `${bgClass} hover:bg-blue-50/50 transition-colors group ${pCode ? `child-of-${pCode}` : ''}`;
            
            let valueCell = '';
            if (isAuto) {
                valueCell = `
                <td class="p-4 border-r border-slate-100 text-right bg-slate-50/50 group-hover:bg-transparent transition-colors font-mono text-slate-700 font-bold" id="auto-val-cell-${row.id}">
                    ${toBanglaCurrency(autoVal)}
                </td>`;
            } else {
                valueCell = `
                <td class="p-3 text-right bg-indigo-50/30 group-hover:bg-transparent transition-colors">
                    <input type="number" min="0" id="manual-${row.id}" value="${manualVal}" placeholder="সম্পাদনা করুন" class="w-full max-w-[180px] ml-auto px-3 py-2 bg-white border border-indigo-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-right font-mono text-indigo-900 font-bold manual-input" ${lockAttr} />
                </td>`;
            }

            tr.innerHTML = `
            <td class="p-3 border-r border-slate-100 text-center">
                <span class="inline-block px-2.5 py-1 bg-slate-200 text-slate-700 font-mono text-sm rounded-lg font-bold">${codeCode}</span>
            </td>
            <td class="p-4 border-r border-slate-100 font-medium text-slate-800">${codeName}</td>
            ${valueCell}
            `;

            tbody.appendChild(tr);
        });

        updateTotal();
        attachInputListeners();
    };

    const attachInputListeners = () => {
        if (isLocked) return;
        let timeoutMap = new Map();
        const inputs = document.querySelectorAll('.manual-input');

        inputs.forEach(input => {
            input.addEventListener('input', () => {
                updateTotal();
            });

            input.addEventListener('blur', (e) => {
                const target = e.target as HTMLInputElement;
                const rowId = target.id.replace('manual-', '');
                
                if (timeoutMap.has(rowId)) clearTimeout(timeoutMap.get(rowId));
                timeoutMap.set(rowId, setTimeout(() => {
                    saveRow(rowId, target);
                }, 500));
            });
        });
    };

    const performRecalculation = async () => {
        if (isLocked) return;
        
        budgetContainer?.classList.add('hidden');
        initLoading?.classList.remove('hidden');
        if (loadingText) loadingText.textContent = strings.budgetSheet.recalculating;
        recalculateBtn?.classList.add('hidden');

        try {
            console.log('Recalculating budget sheet...');
            const newValues = await calculateAll(submissionId, supabase);
            
            // newValues is an array of {submission_id, code_id, auto_value, manual_value}
            // We need to update existing rows with the new auto_value

            for (const newVal of newValues) {
                const existingRow = budgetRows.find(r => r.code_id === newVal.code_id);
                if (existingRow && parseFloat(existingRow.auto_value) !== newVal.auto_value) {
                    await supabase.from('budget_sheet')
                        .update({ auto_value: newVal.auto_value })
                        .eq('id', existingRow.id);
                    
                    existingRow.auto_value = newVal.auto_value;
                } else if (!existingRow) {
                    // This shouldn't happen if initialized correctly, but just in case
                    await supabase.from('budget_sheet').insert(newVal);
                }
            }

            // Refetch to be safe, or just render with updated budgetRows
            const { data: refetched } = await supabase.from('budget_sheet')
            .select(`
                id,
                code_id,
                auto_value,
                manual_value,
                expense_codes (code, name, sort_order, parent_code, parent_title)
            `)
            .eq('submission_id', submissionId);
            
            budgetRows = refetched.sort((a, b) => (a.expense_codes?.sort_order || 0) - (b.expense_codes?.sort_order || 0));
            
            renderTable();

        } catch(e) {
            console.error('Recalculation failed', e);
        } finally {
            initLoading?.classList.add('hidden');
            budgetContainer?.classList.remove('hidden');
            recalculateBtn?.classList.remove('hidden');
        }
    };


    // Load Data
    try {
      const [{ data: subData }, { data: cycleData }] = await Promise.all([
        supabase.from('submissions').select('status').eq('id', submissionId).single(),
        supabase.from('budget_cycles').select('fiscal_year').eq('id', cycleId).single()
      ]);

      if (subData && subData.status === 'submitted') isLocked = true;
      
      const headerTextEl = document.getElementById('budget-header-text');
      if (headerTextEl && cycleData) {
          headerTextEl.textContent = `বাজেট (${cycleData.fiscal_year})`;
      }

      // Check if budget_sheet has data for this submission
      let { data: existingRows } = await supabase.from('budget_sheet')
        .select(`
          id,
          code_id,
          auto_value,
          manual_value,
          expense_codes (code, name, sort_order, parent_code, parent_title)
        `)
        .eq('submission_id', submissionId);

      // If no data, initialize via calculateAll
      if (!existingRows || existingRows.length === 0) {
        console.log('Initializing budget sheet via formula engine...');
        const initData = await calculateAll(submissionId, supabase);
        
        if (initData.length > 0) {
          await supabase.from('budget_sheet').insert(initData);
          
          // Re-fetch with joined codes
          const { data: refetched } = await supabase.from('budget_sheet')
            .select(`
              id,
              code_id,
              auto_value,
              manual_value,
              expense_codes (code, name, sort_order, parent_code, parent_title)
            `)
            .eq('submission_id', submissionId);
            
          existingRows = refetched;
        }
      } else {
        // Automatically perform recalculation on load if not locked and data exists
        if (!isLocked) {
           console.log('Auto-recalculating budget sheet on load...');
           const newValues = await calculateAll(submissionId, supabase);
           let needsRefetch = false;
           for (const newVal of newValues) {
                const existingRow = existingRows.find(r => r.code_id === newVal.code_id);
                if (existingRow && parseFloat(existingRow.auto_value) !== newVal.auto_value) {
                    await supabase.from('budget_sheet')
                        .update({ auto_value: newVal.auto_value })
                        .eq('id', existingRow.id);
                    needsRefetch = true;
                }
            }
            if (needsRefetch) {
                const { data: refetched } = await supabase.from('budget_sheet')
                .select(`
                id,
                code_id,
                auto_value,
                manual_value,
                expense_codes (code, name, sort_order, parent_code, parent_title)
                `)
                .eq('submission_id', submissionId);
                existingRows = refetched;
            }
        }
      }

      // Hide loading, show table
      if (initLoading) initLoading.classList.add('hidden');
      if (budgetContainer) budgetContainer.classList.remove('hidden');
      if (!isLocked && recalculateBtn) recalculateBtn.classList.remove('hidden');

      if (!existingRows) return;

      // Sort by expense_codes.sort_order
      budgetRows = existingRows.sort((a, b) => (a.expense_codes?.sort_order || 0) - (b.expense_codes?.sort_order || 0));

      renderTable();

      // Recalculate button listener
      if (recalculateBtn && !isLocked) {
          recalculateBtn.addEventListener('click', performRecalculation);
      }

      // Show appropriate footer button
      if (isLocked) {
          returnDashboardBtn?.classList.remove('hidden');
      } else {
          finalSubmitBtn?.classList.remove('hidden');
      }

      // Submit handler
      finalSubmitBtn?.addEventListener('click', async () => {
          if (isLocked) return;
          const confirmed = confirm('আপনি কি নিশ্চিত যে এই বাজেট চূড়ান্তভাবে দাখিল করতে চান? দাখিলের পর আর সম্পাদনা করা যাবে না।');
          if (!confirmed) return;

          finalSubmitBtn.disabled = true;
          finalSubmitBtn.textContent = 'দাখিল হচ্ছে...';

          try {
              await supabase.from('submissions')
                  .update({ status: 'submitted', submitted_at: new Date().toISOString() })
                  .eq('id', submissionId);

              alert('বাজেট সফলভাবে দাখিল হয়েছে!');
              window.location.href = '/dashboard';
          } catch (err) {
              console.error('Submit error:', err);
              alert('দাখিল করতে সমস্যা হয়েছে। আবার চেষ্টা করুন।');
              finalSubmitBtn.disabled = false;
              finalSubmitBtn.textContent = 'চূড়ান্ত দাখিল করুন';
          }
      });

    } catch (err) {
      console.error('Error loading budget sheet:', err);
      if (initLoading) initLoading.innerHTML = `<p class="text-red-500">ডেটা লোড করতে সমস্যা হয়েছে।</p>`;
    }
  });
</script>
