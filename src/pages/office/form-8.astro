---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.form8.title} formId="Form 8">
  
  <div class="p-8 md:p-10">
    <div class="mb-4 flex justify-between items-end">
      <div>
        <h2 class="text-xl font-bold text-slate-800 mb-2">{strings.form8.title}</h2>
        <p class="text-slate-500 text-sm flex gap-4">
          <span class="inline-flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-slate-300"></span>
            {strings.form8.annualNote}
          </span>
        </p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form8.utilityType}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form8.annualCost}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form8.due}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100" id="utilities-body">
          <!-- Dynamically populated -->
        </tbody>
      </table>
    </div>

  </div>

  <a href="/office/form-9" slot="footer-action" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md shadow-blue-500/20 flex items-center gap-2">
    {strings.next}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </a>

</FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';

  document.addEventListener('DOMContentLoaded', async () => {
    // 1. Session Check
    const submissionId = sessionStorage.getItem('submission_id');
    if (!submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let isLocked = false;
    let utilityTypes = [];
    let formUtilityData = [];

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Row Logic
    const saveRow = async (utilityTypeId) => {
      if (isLocked) return;
      showSaving();

      const cost = parseInt((document.getElementById(`cost-${utilityTypeId}`) as HTMLInputElement)?.value || '0', 10);
      const due = parseInt((document.getElementById(`due-${utilityTypeId}`) as HTMLInputElement)?.value || '0', 10);

      try {
        const { data: existing } = await supabase.from('form_utility')
          .select('id')
          .eq('submission_id', parseInt(submissionId))
          .eq('utility_type_id', parseInt(utilityTypeId))
          .maybeSingle();

        const payload = {
          submission_id: parseInt(submissionId),
          utility_type_id: parseInt(utilityTypeId),
          annual_cost: cost,
          due: due
        };

        if (existing) {
          await supabase.from('form_utility').update(payload).eq('id', existing.id);
        } else {
          await supabase.from('form_utility').insert(payload);
        }
        
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: utData }, { data: fData }, { data: subData }] = await Promise.all([
        supabase.from('utility_types').select('*').order('id'),
        supabase.from('form_utility').select('*').eq('submission_id', submissionId),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (utData) utilityTypes = utData;
      if (fData) formUtilityData = fData;
      if (subData && subData.status === 'submitted') isLocked = true;

      const tbody = document.getElementById('utilities-body');

      utilityTypes.forEach(ut => {
        const rowData = formUtilityData.find(d => d.utility_type_id === ut.id) || {};
        const lockAttr = isLocked ? 'disabled' : '';

        const nameHtml = `<div class="font-bold text-slate-800">${ut.name}</div>`;
        const costHtml = `<input type="number" min="0" id="cost-${ut.id}" data-ut-id="${ut.id}" value="${rowData.annual_cost || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;
        const dueHtml = `<input type="number" min="0" id="due-${ut.id}" data-ut-id="${ut.id}" value="${rowData.due || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;

        const tr = document.createElement('tr');
        tr.className = 'hover:bg-slate-50 transition-colors';
        tr.innerHTML = `
          <td class="p-4 border-r border-slate-100">${nameHtml}</td>
          <td class="p-3">${costHtml}</td>
          <td class="p-3">${dueHtml}</td>
        `;

        tbody?.appendChild(tr);
      });

      // Attach Event Listeners
      if (!isLocked) {
        const inputs = document.querySelectorAll('.row-input');
        let timeoutMap = new Map();

        inputs.forEach(input => {
          input.addEventListener('blur', (e) => {
            const target = e.target as HTMLInputElement;
            const utId = target.dataset.utId;
            if (!utId) return;

            if (timeoutMap.has(utId)) clearTimeout(timeoutMap.get(utId));
            
            timeoutMap.set(utId, setTimeout(() => {
              saveRow(utId);
            }, 500));
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 8:', err);
    }
  });
</script>
