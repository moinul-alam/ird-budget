---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.forms.form3.title} formId="Form 3" prevUrl="/office/form-2" nextUrl="/office/form-4">
  
  <div class="p-8 md:p-10">
    <div class="mb-4">
      <h2 class="text-xl font-bold text-slate-800 mb-2">{strings.form3.title}</h2>
      <p class="text-slate-500 text-sm flex flex-wrap gap-4">
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-blue-500"></span>
          {strings.form3.calculatedNote}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-slate-300"></span>
          {strings.form3.manualNote}
        </span>
      </p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left border-collapse" id="allowance-table">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="p-4 font-semibold text-slate-700 w-1/4">{strings.form3.allowanceType}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/6">{strings.form3.countLabel}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form3.basicLabel}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form3.amountLabel}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/6">{strings.form3.dueLabel}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100" id="allowance-body">
          <!-- Dynamically populated -->
        </tbody>
        <tfoot class="bg-slate-50/80 border-t-2 border-slate-200 font-bold text-slate-800" id="allowance-footer" style="display: none;">
          <tr>
            <td colspan="3" class="p-4 text-right border-r border-slate-200">{strings.total}:</td>
            <td class="p-4 text-blue-700" id="total-amount">০</td>
            <td class="p-4 text-blue-700" id="total-due">০</td>
          </tr>
        </tfoot>
      </table>
    </div>

  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaCurrency } from '../../lib/bangla.js';
  import { calculateAllowance } from '../../lib/formulas.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-3')) return;
    // 1. Session Check
    const officeId = sessionStorage.getItem('office_id');
    const cycleId = sessionStorage.getItem('cycle_id');
    const submissionId = sessionStorage.getItem('submission_id');
    if (!officeId || !cycleId || !submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let allowanceTypes = [];
    let formAllowancesData = [];
    let isLocked = false;

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Recalculate a row's amount if is_calculated
    const recalculateRow = (typeId) => {
      const type = allowanceTypes.find(a => String(a.id) === String(typeId));
      if (!type || !type.is_calculated) return;

      const countInp = document.getElementById(`count-${typeId}`) as HTMLInputElement;
      const basicInp = document.getElementById(`basic-${typeId}`) as HTMLInputElement;
      const amtInp = document.getElementById(`amount-${typeId}`) as HTMLInputElement;

      const count = parseInt(countInp?.value || '0', 10);
      const basic = parseInt(basicInp?.value || '0', 10);

      const newAmount = calculateAllowance(type.name, count, basic);
      if (amtInp) amtInp.value = newAmount > 0 ? newAmount.toString() : '';
    };

    // Update footer totals
    const updateTotals = () => {
      let totalAmount = 0;
      let totalDue = 0;

      allowanceTypes.forEach(type => {
        const amtInp = document.getElementById(`amount-${type.id}`) as HTMLInputElement;
        const dueInp = document.getElementById(`due-${type.id}`) as HTMLInputElement;
        
        totalAmount += parseInt(amtInp?.value || '0', 10);
        totalDue += parseInt(dueInp?.value || '0', 10);
      });

      document.getElementById('total-amount')!.textContent = toBanglaCurrency(totalAmount, false);
      document.getElementById('total-due')!.textContent = toBanglaCurrency(totalDue, false);
    };

    // Handle input events: recalculate + update totals
    const handleInput = (e) => {
      const target = e.target as HTMLInputElement;
      const typeId = target.dataset.typeId;
      if (typeId) recalculateRow(typeId);
      updateTotals();
    };

    // Save Row Logic (UPSERT or DELETE)
    const saveRow = async (typeId) => {
      if (isLocked) return;
      showSaving();

      const count = parseInt((document.getElementById(`count-${typeId}`) as HTMLInputElement)?.value || '0', 10);
      const basic = parseInt((document.getElementById(`basic-${typeId}`) as HTMLInputElement)?.value || '0', 10);
      const amount = parseInt((document.getElementById(`amount-${typeId}`) as HTMLInputElement)?.value || '0', 10);
      const due = parseInt((document.getElementById(`due-${typeId}`) as HTMLInputElement)?.value || '0', 10);

      const isZero = count === 0 && basic === 0 && amount === 0 && due === 0;

      try {
        if (isZero) {
          await supabase.from('form_allowances')
            .delete()
            .eq('submission_id', parseInt(submissionId))
            .eq('allowance_type_id', parseInt(typeId));
        } else {
          const { data: existing } = await supabase.from('form_allowances')
            .select('id')
            .eq('submission_id', parseInt(submissionId))
            .eq('allowance_type_id', parseInt(typeId))
            .maybeSingle();

          const payload = {
            submission_id: parseInt(submissionId),
            allowance_type_id: parseInt(typeId),
            count,
            total_basic: basic,
            amount,
            due
          };

          if (existing) {
            await supabase.from('form_allowances').update(payload).eq('id', existing.id);
          } else {
            await supabase.from('form_allowances').insert(payload);
          }
        }
        
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: typesData, error: typesError }, { data: fData }, { data: subData }] = await Promise.all([
        supabase.from('allowance_types').select('*').order('id'),
        supabase.from('form_allowances').select('*').eq('submission_id', submissionId),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      console.log('allowance_types query result:', { typesData, typesError });

      if (typesError) {
        console.error('Failed to load allowance_types:', typesError.message);
      }

      if (typesData) allowanceTypes = typesData;
      if (fData) formAllowancesData = fData;
      if (subData && subData.status === 'submitted') isLocked = true;

      const tbody = document.getElementById('allowance-body');

      // Name mapping: allowance_types.name → strings.form3[name]
      const nameMap = {
        overtime: strings.form3.overtime,
        duty: strings.form3.duty,
        dress: strings.form3.dress,
        risk: strings.form3.risk,
        hill: strings.form3.hill,
      };
      
      allowanceTypes.forEach(type => {
        const rowData = formAllowancesData.find(d => d.allowance_type_id === type.id) || {};
        const displayName = nameMap[type.name] || type.name;
        const lockAttr = isLocked ? 'disabled' : '';

        // Name cell with calculated indicator
        const dot = type.is_calculated
          ? '<div class="w-2 h-2 rounded-full bg-blue-500 shrink-0"></div>'
          : '<div class="w-2 h-2 rounded-full bg-slate-300 shrink-0"></div>';
        const nameHtml = `<div class="flex items-center gap-2">${dot}<span class="font-bold text-slate-800">${displayName}</span></div>`;

        // Count input (always available)
        const countHtml = `<input type="number" min="0" id="count-${type.id}" data-type-id="${type.id}" value="${rowData.count || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;

        // Basic input (only if has_basic)
        const basicHtml = type.has_basic
          ? `<input type="number" min="0" id="basic-${type.id}" data-type-id="${type.id}" value="${rowData.total_basic || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`
          : `<div class="px-3 py-2 text-slate-300 text-center">—</div>`;

        // Amount input (readonly if is_calculated)
        const amountHtml = type.is_calculated
          ? `<input type="number" id="amount-${type.id}" data-type-id="${type.id}" value="${rowData.amount || ''}" class="w-full px-3 py-2 bg-blue-50 border border-blue-100 rounded-lg text-blue-900 font-semibold cursor-not-allowed row-input" readonly tabindex="-1" />`
          : `<input type="number" min="0" id="amount-${type.id}" data-type-id="${type.id}" value="${rowData.amount || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;

        // Due input
        const dueHtml = `<input type="number" min="0" id="due-${type.id}" data-type-id="${type.id}" value="${rowData.due || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;

        const tr = document.createElement('tr');
        tr.className = 'hover:bg-slate-50 transition-colors';
        tr.innerHTML = `
          <td class="p-4 border-r border-slate-100">${nameHtml}</td>
          <td class="p-3">${countHtml}</td>
          <td class="p-3">${basicHtml}</td>
          <td class="p-3">${amountHtml}</td>
          <td class="p-3">${dueHtml}</td>
        `;

        tbody?.appendChild(tr);
      });

      // Show footer and compute initial totals
      document.getElementById('allowance-footer')!.style.display = 'table-footer-group';
      updateTotals();

      // Attach Event Listeners (skip if locked)
      if (!isLocked) {
        const inputs = document.querySelectorAll('.row-input');
        let timeoutMap = new Map();

        inputs.forEach(input => {
          // Real-time calculation on input
          input.addEventListener('input', handleInput);

          // Debounced save on blur
          input.addEventListener('blur', (e) => {
            const target = e.target as HTMLInputElement;
            const typeId = target.dataset.typeId;
            if (!typeId) return;

            if (timeoutMap.has(typeId)) clearTimeout(timeoutMap.get(typeId));
            
            timeoutMap.set(typeId, setTimeout(() => {
              saveRow(typeId);
            }, 500));
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 3:', err);
    }


    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', () => {
        // Trigger blur on active element to fire auto-save, or just trigger save
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Show saving if not already shown by blur
        const saveIndicator = document.getElementById('save-indicator');
        const saveSpinner = document.getElementById('save-spinner');
        const saveCheck = document.getElementById('save-check');
        const saveText = document.getElementById('save-text');
        
        if (saveIndicator) saveIndicator.classList.remove('opacity-0');
        if (saveSpinner) saveSpinner.classList.remove('hidden');
        if (saveCheck) saveCheck.classList.add('hidden');
        if (saveText) saveText.textContent = strings.saving || 'সংরক্ষণ করা হচ্ছে...';
        
        // Let auto-save handle the actual save, if nothing was active, nothing to save but visual feedback helps
      });
    }
  });
</script>
