---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="mb-8">
        <a href={`/office/${Astro.params.id}`} class="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          ফিরে যান
        </a>
        <h1 class="text-3xl font-bold text-gray-800">ফর্ম ৪: যন্ত্রপাতি ও সরঞ্জামের তথ্য</h1>
        <p class="text-gray-600 mt-2">আপনার অফিসের যন্ত্রপাতি ও সরঞ্জামের বিস্তারিত তথ্য পূরণ করুন</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <form id="equipment-form" class="space-y-6">
          <div id="equipment-container" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
          <div class="flex items-center justify-between pt-4">
            <div id="save-status" class="text-sm text-gray-600"></div>
            <button type="submit" id="save-button" class="px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition">
              সংরক্ষণ করুন
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const officeParam = Astro.params.id;
    const equipmentTypes = ['কম্পিউটার', 'প্রিন্টার', 'এসি', 'ফটোকপি মেশিন', 'স্ক্যানার'];
    let submissionId = null;

    async function init() {
      let { data: office } = await supabase.from('offices').select('*').eq('office_id', officeParam).maybeSingle();
      if (!office) { window.location.href = '/'; return; }
      
      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      if (!cycle) { alert('কোনো চক্র খোলা নেই।'); return; }
      
      let { data: submission } = await supabase.from('submissions').select('*').eq('office_id', office.id).eq('cycle_id', cycle.id).maybeSingle();
      if (!submission) {
        const { data: newSub } = await supabase.from('submissions').insert({ office_id: office.id, cycle_id: cycle.id }).select().single();
        submission = newSub;
      }
      submissionId = submission.id;
      
      const { data: existingEquip } = await supabase.from('form_equipment').select('*').eq('submission_id', submissionId);
      const equipMap = {};
      existingEquip?.forEach(eq => equipMap[eq.equipment_type] = eq);
      
      const container = document.getElementById('equipment-container');
      container.innerHTML = equipmentTypes.map(type => `
        <div class="border border-gray-200 rounded-lg p-6 bg-gray-50">
          <h3 class="text-lg font-medium text-gray-800 mb-4">${type}</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm text-gray-600 mb-2">সংখ্যা</label>
              <input type="number" min="0" id="count-${type}" value="${equipMap[type]?.count || 0}" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-2">একক মূল্য (টাকা)</label>
              <input type="number" min="0" id="cost-${type}" value="${equipMap[type]?.unit_cost || 0}" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>
        </div>
      `).join('');
      
      document.getElementById('equipment-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const saveBtn = document.getElementById('save-button');
        const status = document.getElementById('save-status');
        saveBtn.disabled = true;
        status.textContent = 'সংরক্ষণ হচ্ছে...';
        
        try {
          for (const type of equipmentTypes) {
            const count = parseInt(document.getElementById(`count-${type}`).value) || 0;
            const cost = parseFloat(document.getElementById(`cost-${type}`).value) || 0;
            const existing = (await supabase.from('form_equipment').select('*').eq('submission_id', submissionId).eq('equipment_type', type).maybeSingle()).data;
            existing 
              ? await supabase.from('form_equipment').update({ count, unit_cost: cost }).eq('id', existing.id)
              : await supabase.from('form_equipment').insert({ submission_id: submissionId, equipment_type: type, count, unit_cost: cost });
          }
          status.textContent = '✓ সংরক্ষিত হয়েছে';
          status.className = 'text-sm text-green-600';
        } catch (err) {
          status.textContent = '✗ সমস্যা হয়েছে';
          status.className = 'text-sm text-red-600';
        } finally {
          saveBtn.disabled = false;
        }
      });
    }
    init();
  </script>
</Layout>
