---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href={`/office/${Astro.params.id}`} class="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          ফিরে যান
        </a>
        <h1 class="text-3xl font-bold text-gray-800">ফর্ম ২: কর্মকর্তা ও কর্মচারীর তথ্য</h1>
        <p class="text-gray-600 mt-2">প্রতিটি গ্রেডের কর্মকর্তা ও কর্মচারীর সংখ্যা ও গড় মূল বেতন পূরণ করুন</p>
      </div>

      <!-- Form Card -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <form id="staff-form" class="space-y-8">
          <!-- Officers Section -->
          <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">কর্মকর্তা (Grade 1-9)</h2>
            <div id="officers-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
          </div>

          <!-- Staff Section -->
          <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">কর্মচারী (Grade 10-20)</h2>
            <div id="staff-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
          </div>

          <!-- Buttons -->
          <div class="flex items-center justify-between pt-4">
            <div id="save-status" class="text-sm text-gray-600"></div>
            <button 
              type="submit" 
              id="save-button"
              class="px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition"
            >
              সংরক্ষণ করুন
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const officeParam = Astro.params.id;
    let grades = [];
    let submissionId = null;

    async function init() {
      // 1. Get grades from DB
      const { data: gradesData } = await supabase.from('grades').select('*').order('grade_no');
      grades = gradesData;

      // 2. Get or create office and submission
      let { data: office } = await supabase.from('offices').select('*').eq('office_id', officeParam).maybeSingle();
      if (!office) {
        alert('প্রথমে অফিস তৈরি করুন।');
        window.location.href = '/';
        return;
      }

      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      if (!cycle) {
        alert('বর্তমানে কোনো দাখিলের চক্র খোলা নেই।');
        return;
      }

      let { data: submission } = await supabase.from('submissions').select('*').eq('office_id', office.id).eq('cycle_id', cycle.id).maybeSingle();
      if (!submission) {
        const { data: newSub } = await supabase.from('submissions').insert({
          office_id: office.id,
          cycle_id: cycle.id
        }).select().single();
        submission = newSub;
      }
      submissionId = submission.id;

      // 3. Load existing staff data
      const { data: existingStaff } = await supabase.from('form_staff').select('*').eq('submission_id', submissionId);
      const staffMap = {};
      existingStaff?.forEach(s => staffMap[s.grade_id] = s);

      // 4. Render grids
      const officersGrid = document.getElementById('officers-grid');
      const staffGrid = document.getElementById('staff-grid');
      officersGrid.innerHTML = '';
      staffGrid.innerHTML = '';

      grades.forEach(grade => {
        const staff = staffMap[grade.id];
        const html = `
          <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
            <h3 class="font-medium text-gray-800 mb-3">${grade.label}</h3>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm text-gray-600 mb-1">সংখ্যা</label>
                <input 
                  type="number" 
                  min="0"
                  id="count-${grade.id}" 
                  value="${staff?.count || 0}"
                  class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                />
              </div>
              <div>
                <label class="block text-sm text-gray-600 mb-1">গড় মূল বেতন (টাকা)</label>
                <input 
                  type="number" 
                  min="0"
                  id="avg-basic-${grade.id}" 
                  value="${staff?.avg_basic || 0}"
                  class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                />
              </div>
            </div>
          </div>
        `;
        if (grade.category === 'officer') {
          officersGrid.innerHTML += html;
        } else {
          staffGrid.innerHTML += html;
        }
      });

      // 5. Form submit handler
      document.getElementById('staff-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const saveButton = document.getElementById('save-button');
        const saveStatus = document.getElementById('save-status');
        saveButton.disabled = true;
        saveStatus.textContent = 'সংরক্ষণ হচ্ছে...';
        saveStatus.className = 'text-sm text-yellow-600';

        try {
          for (const grade of grades) {
            const count = parseInt(document.getElementById(`count-${grade.id}`).value) || 0;
            const avgBasic = parseFloat(document.getElementById(`avg-basic-${grade.id}`).value) || 0;

            const { data: existing } = await supabase.from('form_staff').select('*').eq('submission_id', submissionId).eq('grade_id', grade.id).maybeSingle();
            
            if (existing) {
              await supabase.from('form_staff').update({ count, avg_basic: avgBasic }).eq('id', existing.id);
            } else {
              await supabase.from('form_staff').insert({ submission_id: submissionId, grade_id: grade.id, count, avg_basic: avgBasic });
            }
          }

          saveStatus.textContent = '✓ সংরক্ষিত হয়েছে';
          saveStatus.className = 'text-sm text-green-600';
        } catch (error) {
          console.error(error);
          saveStatus.textContent = '✗ সংরক্ষণ করতে সমস্যা হয়েছে';
          saveStatus.className = 'text-sm text-red-600';
        } finally {
          saveButton.disabled = false;
        }
      });
    }

    init();
  </script>
</Layout>
