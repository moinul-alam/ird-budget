---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <h1 class="text-4xl font-extrabold text-gray-800">অফিস ড্যাশবোর্ড</h1>
            <p class="text-gray-600 mt-1">আপনার বাজেট প্রক্রিয়ার সব তথ্য এক জায়গায়</p>
          </div>
        </div>
      </div>
      
      <!-- Office Info Card -->
      <div id="office-info" class="mb-8"></div>
      
      <!-- Cycle Info Card -->
      <div id="cycle-info" class="mb-10"></div>
      
      <!-- Forms Section -->
      <div class="mb-10">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            ফর্মসমূহ
          </h2>
        </div>
        <div id="forms-list" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
      </div>
      
      <!-- Actions Section -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <button id="budget-btn" class="group flex items-center justify-center gap-3 px-8 py-6 bg-white rounded-2xl border border-gray-100 shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1">
          <div class="w-12 h-12 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="text-left">
            <span class="block text-xl font-bold text-gray-800">বাজেট শিট দেখুন</span>
            <span class="text-sm text-gray-500">গণনাকৃত বাজেট দেখুন</span>
          </div>
        </button>
        <button id="submit-btn" class="group flex items-center justify-center gap-3 px-8 py-6 bg-white rounded-2xl border border-gray-100 shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1">
          <div class="w-12 h-12 bg-gradient-to-r from-emerald-600 to-teal-600 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="text-left">
            <span class="block text-xl font-bold text-gray-800">চূড়ান্ত দাখিল করুন</span>
            <span class="text-sm text-gray-500">বাজেট শেষ করুন</span>
          </div>
        </button>
      </div>
    </div>
  </div>
  
  <script>
    import { supabase } from '../../lib/supabase';

    const officeParam = Astro.params.id;
    let officeData = null;

    async function loadOffice() {
      const { data: office } = await supabase.from('offices').select('*, office_groups(*)').eq('office_id', officeParam).maybeSingle();
      officeData = office;
      const officeInfoDiv = document.getElementById('office-info');
      
      if (office) {
        officeInfoDiv.innerHTML = `
          <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-10 py-6">
              <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <h3 class="text-2xl font-bold text-white">অফিস তথ্য</h3>
              </div>
            </div>
            <div class="p-10">
              <h4 class="text-3xl font-extrabold text-gray-800 mb-6">${office.name}</h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">অফিস কোড</span>
                  <p class="text-xl font-mono font-bold text-gray-700">${office.office_id}</p>
                </div>
                <div class="space-y-2">
                  <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">গ্রুপ</span>
                  <p class="text-xl font-bold text-gray-700">${office.office_groups?.name || 'নির্ধারিত নেই'}</p>
                </div>
                ${office.parent_office ? `
                <div class="space-y-2 md:col-span-2">
                  <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">উর্দ্ধতন অফিস</span>
                  <p class="text-xl font-bold text-gray-700">${office.parent_office}</p>
                </div>
                ` : ''}
                ${office.address ? `
                <div class="space-y-2 md:col-span-2">
                  <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">ঠিকানা</span>
                  <p class="text-xl text-gray-700">${office.address}</p>
                </div>
                ` : ''}
              </div>
            </div>
          </div>
        `;
      } else {
        officeInfoDiv.innerHTML = `
          <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 p-12 text-center">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-3">এই কোডে কোনো অফিস পাওয়া যায়নি</h3>
            <p class="text-gray-600 mb-8">সঠিক অফিস কোড দিয়ে আবার চেষ্টা করুন</p>
            <a href="/" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-2xl hover:from-blue-700 hover:to-indigo-700 transition-all shadow-xl">
              হোম পেজে ফিরে যান
            </a>
          </div>
        `;
      }
    }

    async function loadCycle() {
      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      const cycleInfoDiv = document.getElementById('cycle-info');
      
      if (!cycle) {
        cycleInfoDiv.innerHTML = `
          <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
            <div class="bg-gradient-to-r from-yellow-500 to-orange-500 px-10 py-6">
              <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h3 class="text-2xl font-bold text-white">সর্বশেষ চক্র</h3>
              </div>
            </div>
            <div class="p-10 text-center">
              <p class="text-xl font-semibold text-yellow-600">বর্তমানে কোনো দাখিলের চক্র খোলা নেই!</p>
            </div>
          </div>
        `;
        return;
      }

      let submissionStatus = 'খসড়া নেই';
      let statusColor = 'text-gray-600';
      let statusBg = 'bg-gray-100';
      
      if (officeData) {
        const { data: submission } = await supabase.from('submissions').select('*').eq('office_id', officeData.id).eq('cycle_id', cycle.id).maybeSingle();
        if (submission) {
          submissionStatus = submission.status === 'draft' ? 'খসড়া' : 'দাখিলকৃত';
          statusColor = submission.status === 'draft' ? 'text-blue-600' : 'text-green-600';
          statusBg = submission.status === 'draft' ? 'bg-blue-100' : 'bg-green-100';
        }
      }

      cycleInfoDiv.innerHTML = `
        <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-10 py-6">
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <h3 class="text-2xl font-bold text-white">সক্রিয় দাখিল চক্র</h3>
            </div>
          </div>
          <div class="p-10">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="space-y-2">
                <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">অর্থবছর</span>
                <p class="text-2xl font-bold text-gray-800">${cycle.fiscal_year}</p>
              </div>
              <div class="space-y-2">
                <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">ধরন</span>
                <p class="text-2xl font-bold text-gray-800">${cycle.type === 'estimated' ? 'প্রাক্কলিত' : 'সংশোধিত'}</p>
              </div>
              <div class="space-y-2">
                <span class="text-gray-500 text-sm font-semibold uppercase tracking-wider">আপনার অবস্থা</span>
                <span class="inline-block px-5 py-2 rounded-full text-lg font-bold ${statusColor} ${statusBg}">${submissionStatus}</span>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    async function loadForms() {
      const forms = [
        { id: 1, name: 'অফিসের মূল তথ্য', url: `/office/${officeParam}/form-1`, status: 'pending', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
        { id: 2, name: 'কর্মকর্তা ও কর্মচারীর তথ্য', url: `/office/${officeParam}/form-2`, status: 'pending', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z' },
        { id: 3, name: 'যানবাহনের তথ্য', url: '#', status: 'locked', icon: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4' },
        { id: 4, name: 'যন্ত্রপাতি ও সরঞ্জামের তথ্য', url: '#', status: 'locked', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z' },
        { id: 5, name: 'ইউটিলিটি খরচের তথ্য', url: '#', status: 'locked', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
        { id: 6, name: 'জ্বালানি তেলের তথ্য', url: '#', status: 'locked', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
        { id: 7, name: 'ভাড়ার তথ্য', url: '#', status: 'locked', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
        { id: 8, name: 'বিবিধ তথ্য', url: '#', status: 'locked', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' }
      ];

      const formsList = document.getElementById('forms-list');
      formsList.innerHTML = forms.map(form => {
        let cardClass = '';
        let iconBg = '';
        let statusIcon = '';
        let statusText = '';
        let isClickable = true;
        
        if (form.status === 'pending') {
          cardClass = 'hover:shadow-2xl transform hover:-translate-y-2 cursor-pointer border-2 border-transparent hover:border-blue-200';
          iconBg = 'bg-gradient-to-r from-blue-600 to-indigo-600';
          statusIcon = '📝';
          statusText = 'খালি';
        } else if (form.status === 'locked') {
          cardClass = 'opacity-70 cursor-not-allowed border-2 border-gray-100';
          iconBg = 'bg-gradient-to-r from-gray-400 to-gray-500';
          statusIcon = '🔒';
          statusText = 'শীঘ্রই আসছে';
          isClickable = false;
        }
        
        return `
          <a href="${isClickable ? form.url : '#'}" class="bg-white rounded-2xl shadow-xl border border-gray-100 p-7 ${cardClass} transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-14 h-14 ${iconBg} rounded-2xl flex items-center justify-center shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="${form.icon}"/>
                </svg>
              </div>
              <span class="text-2xl">${statusIcon}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">ফর্ম ${form.id}</h3>
            <p class="text-gray-600 mb-4">${form.name}</p>
            <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm font-semibold">${statusText}</span>
          </a>
        `;
      }).join('');
    }

    document.getElementById('budget-btn').addEventListener('click', () => {
      window.location.href = `/office/${officeParam}/budget`;
    });

    document.getElementById('submit-btn').addEventListener('click', () => {
      window.location.href = `/office/${officeParam}/submit`;
    });

    loadOffice();
    loadCycle();
    loadForms();
  </script>
</Layout>
