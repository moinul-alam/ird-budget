---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="mb-8">
        <a href={`/office/${Astro.params.id}`} class="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          ফিরে যান
        </a>
        <h1 class="text-3xl font-bold text-gray-800">ফর্ম ৫: ইউটিলিটি খরচের তথ্য</h1>
        <p class="text-gray-600 mt-2">আপনার অফিসের মাসিক ইউটিলিটি খরচ পূরণ করুন</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <form id="utility-form" class="space-y-6">
          <div class="space-y-6">
            <div>
              <label for="electricity" class="block text-sm font-medium text-gray-700 mb-2">বৈদ্যুতিক বিল (মাসিক, টাকা)</label>
              <input type="number" min="0" id="electricity" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label for="water" class="block text-sm font-medium text-gray-700 mb-2">পানি বিল (মাসিক, টাকা)</label>
              <input type="number" min="0" id="water" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label for="gas" class="block text-sm font-medium text-gray-700 mb-2">গ্যাস বিল (মাসিক, টাকা)</label>
              <input type="number" min="0" id="gas" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label for="internet" class="block text-sm font-medium text-gray-700 mb-2">ইন্টারনেট/টেলিফোন বিল (মাসিক, টাকা)</label>
              <input type="number" min="0" id="internet" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>
          <div class="flex items-center justify-between pt-4">
            <div id="save-status" class="text-sm text-gray-600"></div>
            <button type="submit" id="save-button" class="px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition">
              সংরক্ষণ করুন
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const officeParam = Astro.params.id;
    let submissionId = null;

    async function init() {
      let { data: office } = await supabase.from('offices').select('*').eq('office_id', officeParam).maybeSingle();
      if (!office) { window.location.href = '/'; return; }
      
      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      if (!cycle) { alert('কোনো চক্র খোলা নেই।'); return; }
      
      let { data: submission } = await supabase.from('submissions').select('*').eq('office_id', office.id).eq('cycle_id', cycle.id).maybeSingle();
      if (!submission) {
        const { data: newSub } = await supabase.from('submissions').insert({ office_id: office.id, cycle_id: cycle.id }).select().single();
        submission = newSub;
      }
      submissionId = submission.id;
      
      const { data: existing } = await supabase.from('form_utility').select('*').eq('submission_id', submissionId).maybeSingle();
      if (existing) {
        document.getElementById('electricity').value = existing.electricity_monthly || 0;
        document.getElementById('water').value = existing.water_monthly || 0;
        document.getElementById('gas').value = existing.gas_monthly || 0;
        document.getElementById('internet').value = existing.internet_monthly || 0;
      }
      
      document.getElementById('utility-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const saveBtn = document.getElementById('save-button');
        const status = document.getElementById('save-status');
        saveBtn.disabled = true;
        status.textContent = 'সংরক্ষণ হচ্ছে...';
        
        try {
          const data = {
            electricity_monthly: parseFloat(document.getElementById('electricity').value) || 0,
            water_monthly: parseFloat(document.getElementById('water').value) || 0,
            gas_monthly: parseFloat(document.getElementById('gas').value) || 0,
            internet_monthly: parseFloat(document.getElementById('internet').value) || 0
          };
          
          existing 
            ? await supabase.from('form_utility').update(data).eq('id', existing.id)
            : await supabase.from('form_utility').insert({ ...data, submission_id: submissionId });
            
          status.textContent = '✓ সংরক্ষিত হয়েছে';
          status.className = 'text-sm text-green-600';
        } catch (err) {
          status.textContent = '✗ সমস্যা হয়েছে';
          status.className = 'text-sm text-red-600';
        } finally {
          saveBtn.disabled = false;
        }
      });
    }
    init();
  </script>
</Layout>
