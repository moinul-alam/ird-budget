---
import Layout from '../../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-4xl mx-auto">
      <a href={`/office/${Astro.params.id}`} class="text-blue-600 mb-4 inline-block">&larr; পিছনে</a>
      <h1 class="text-2xl font-bold mb-6">চূড়ান্ত দাখিল</h1>
      <div class="bg-white p-6 rounded shadow">
        <button id="final-submit" class="w-full bg-green-600 text-white p-3 rounded hover:bg-green-700">চূড়ান্তভাবে দাখিল করুন</button>
      </div>
    </div>
  </div>
  <script>
    import { supabase } from '../../../lib/supabase';

    const officeId = Astro.params.id;

    document.getElementById('final-submit').addEventListener('click', async () => {
      if (!confirm('আপনি কি নিশ্চিত?')) return;

      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      if (!cycle) return;

      const { data: submission } = await supabase.from('submissions').select('*').eq('office_id', officeId).eq('cycle_id', cycle.id).maybeSingle();
      if (!submission) return;

      await supabase.from('submissions').update({ status: 'submitted', submitted_at: new Date().toISOString() }).eq('id', submission.id);

      window.location.href = `/office/${officeId}`;
    });
  </script>
</Layout>
