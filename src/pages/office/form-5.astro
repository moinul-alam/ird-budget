---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.form5.title} formId="Form 5" prevUrl="/office/form-4" nextUrl="/office/form-6">
  
  <div class="p-8 md:p-10">
    <div class="mb-6 flex justify-between items-end">
      <div>
        <h2 class="text-xl font-bold text-slate-800 mb-2">{strings.form5.title}</h2>
      </div>
      <button id="add-btn" class="px-5 py-2.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 font-bold rounded-xl transition-colors border border-emerald-200 shadow-sm flex items-center gap-2 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        {strings.form5.addVehicle}
      </button>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left border-collapse" id="vehicles-table">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form5.vehicleType}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form5.fuelType}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/6">{strings.form5.countLabel}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form5.maintenanceCost}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/5">{strings.form5.additionalExpense}</th>
            <th class="p-4 font-semibold text-slate-700 w-16"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100" id="vehicles-body">
          <!-- Dynamically populated -->
        </tbody>
      </table>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden py-12 text-center text-slate-500 bg-slate-50 rounded-2xl border border-slate-200 mt-4 flex flex-col items-center justify-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p>{strings.form5.noVehicle}</p>
    </div>

  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-5')) return;
    // 1. Session Check
    const submissionId = sessionStorage.getItem('submission_id');
    if (!submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let isLocked = false;
    let configs: any[] = [];
    let formVehiclesData: any[] = [];

    // Unique UI logic
    const tbody = document.getElementById('vehicles-body') as HTMLElement;
    const emptyState = document.getElementById('empty-state') as HTMLElement;
    const table = document.getElementById('vehicles-table') as HTMLElement;

    // Extract unique car types and their valid fuels from configs
    const getCars = () => {
      const cars = new Map();
      configs.forEach(c => {
        if (!cars.has(c.car_type_id)) {
          cars.set(c.car_type_id, { id: c.car_type_id, name: c.car_types.name, fuels: [] });
        }
        cars.get(c.car_type_id).fuels.push({ id: c.fuel_type_id, name: c.fuel_types.name, configId: c.id });
      });
      return Array.from(cars.values());
    };

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Row Logic
    const saveRow = async (rowEl: any) => {
      if (isLocked) return;

      const recordId = rowEl.dataset.recordId;
      const configId = rowEl.dataset.configId;

      if (!configId) return; // Haven't selected both dropdowns yet

      showSaving();

      const count = parseInt(rowEl.querySelector('.count-input').value || '0', 10);
      const mCost = parseInt(rowEl.querySelector('.mcost-input').value || '0', 10);
      const aExp = parseInt(rowEl.querySelector('.aexp-input').value || '0', 10);

      const payload = {
        submission_id: parseInt(submissionId),
        vehicle_fuel_config_id: parseInt(configId),
        count,
        maintenance_cost: mCost,
        additional_expense: aExp
      };

      try {
        if (recordId) {
          await supabase.from('form_vehicles').update(payload).eq('id', recordId);
        } else {
          // Check if it already exists (to handle unique constraint safely)
          const { data: existing } = await supabase.from('form_vehicles')
            .select('id')
            .eq('submission_id', parseInt(submissionId))
            .eq('vehicle_fuel_config_id', parseInt(configId))
            .maybeSingle();

          if (existing) {
            await supabase.from('form_vehicles').update(payload).eq('id', existing.id);
            rowEl.dataset.recordId = existing.id;
          } else {
            const { data } = await supabase.from('form_vehicles').insert(payload).select('id').single();
            if (data) rowEl.dataset.recordId = data.id;
          }
        }
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    const deleteRow = async (rowEl: HTMLElement) => {
      if (isLocked) return;
      const recordId = rowEl.dataset.recordId;
      if (recordId) {
        showSaving();
        await supabase.from('form_vehicles').delete().eq('id', recordId);
        showSaved();
      }
      rowEl.remove();
      updateVisibility();
    };

    const updateVisibility = () => {
      const tbody = document.getElementById('vehicles-body');
      const table = document.getElementById('vehicles-table');
      const emptyState = document.getElementById('empty-state');
      if (!tbody || !table || !emptyState) return;

      if (tbody.children.length === 0) {
        table.classList.add('hidden');
        emptyState.classList.remove('hidden');
      } else {
        table.classList.remove('hidden');
        emptyState.classList.add('hidden');
      }
    };

    // Create a DOM row
    const renderRow = (initialData: any = null) => {
      const lockAttr = isLocked ? 'disabled' : '';
      const cars = getCars();

      const tr = document.createElement('tr');
      tr.className = 'hover:bg-slate-50 transition-colors group';
      if (initialData?.id) tr.dataset.recordId = initialData.id;
      if (initialData?.vehicle_fuel_config_id) tr.dataset.configId = initialData.vehicle_fuel_config_id;

      // HTML template
      tr.innerHTML = `
        <td class="p-3 border-r border-slate-100">
          <select class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none car-select" ${lockAttr}>
            <option value="">নির্বাচন করুন</option>
            ${cars.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
          </select>
        </td>
        <td class="p-3 border-r border-slate-100">
          <select class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none fuel-select" ${lockAttr}>
            <option value="">আগে গাড়ি নির্বাচন করুন</option>
          </select>
        </td>
        <td class="p-3"><input type="number" min="0" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none count-input row-input" value="${initialData?.count || ''}" ${lockAttr} /></td>
        <td class="p-3"><input type="number" min="0" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none mcost-input row-input" value="${initialData?.maintenance_cost || ''}" ${lockAttr} /></td>
        <td class="p-3"><input type="number" min="0" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none aexp-input row-input" value="${initialData?.additional_expense || ''}" ${lockAttr} /></td>
        <td class="p-3 text-center">
          <button class="text-slate-300 hover:text-red-500 transition-colors delete-btn p-2 rounded-lg hover:bg-red-50" ${lockAttr} title="মুছে ফেলুন">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
          </button>
        </td>
      `;

      tbody.appendChild(tr);

      // Elements
      const carSelect = tr.querySelector('.car-select');
      const fuelSelect = tr.querySelector('.fuel-select');
      const inputs = tr.querySelectorAll('.row-input');
      const delBtn = tr.querySelector('.delete-btn');

      // Setup initial data if available
      if (initialData) {
        const config = configs.find(c => c.id === initialData.vehicle_fuel_config_id);
        if (config && carSelect && fuelSelect) {
          (carSelect as HTMLSelectElement).value = config.car_type_id;
          // Trigger fuel population
          const selectedCar = cars.find(c => c.id == config.car_type_id);
          fuelSelect.innerHTML = `<option value="">নির্বাচন করুন</option>` + 
            selectedCar.fuels.map((f: any) => `<option value="${f.id}" data-config-id="${f.configId}">${f.name}</option>`).join('');
          (fuelSelect as HTMLSelectElement).value = config.fuel_type_id;
        }
      }

      // Event Listeners
      let timeoutMap: any = undefined;
      if (!isLocked) {

        // Cascade logic
        carSelect?.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          const carId = parseInt(target.value);
          if (!carId) {
            if (fuelSelect) fuelSelect.innerHTML = '<option value="">আগে গাড়ি নির্বাচন করুন</option>';
            tr.dataset.configId = '';
            return;
          }
          const selectedCar = cars.find(c => c.id === carId);
          if (fuelSelect) fuelSelect.innerHTML = `<option value="">নির্বাচন করুন</option>` + 
            selectedCar.fuels.map((f: any) => `<option value="${f.id}" data-config-id="${f.configId}">${f.name}</option>`).join('');
          tr.dataset.configId = ''; // Reset until fuel is chosen
        });

        fuelSelect?.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          const selectedOption = target.options[target.selectedIndex];
          const cId = selectedOption.dataset.configId;
          tr.dataset.configId = cId || '';
          if (cId) saveRow(tr); // Save once combo is finalized
        });

        // Input blur logic
        inputs.forEach(inp => {
          inp.addEventListener('blur', () => {
            clearTimeout(timeoutMap);
            timeoutMap = setTimeout(() => saveRow(tr), 500);
          });
        });

        // Delete logic
        if (delBtn) delBtn.addEventListener('click', () => deleteRow(tr));
      }

      updateVisibility();
    };

    document.getElementById('add-btn')?.addEventListener('click', () => renderRow());

    // Load Data Phase
    try {
      const [{ data: configData, error: configError }, { data: fData }, { data: subData }] = await Promise.all([
        supabase.from('vehicle_fuel_config').select(`
          id, car_type_id, fuel_type_id,
          car_types (name),
          fuel_types (name)
        `).order('id'),
        supabase.from('form_vehicles').select('*').eq('submission_id', submissionId),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (configData) configs = configData;
      if (fData) formVehiclesData = fData;
      if (subData && subData.status === 'submitted') {
        isLocked = true;
        const addBtn = document.getElementById('add-btn');
        if (addBtn) addBtn.style.display = 'none';
      }

      // Render existing rows
      if (formVehiclesData.length > 0) {
        formVehiclesData.forEach(d => renderRow(d));
      } else {
        updateVisibility();
      }

    } catch (err) {
      console.error('Error loading form 5:', err);
    }

    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', async () => {
        // Disable button
        (manualSaveBtn as HTMLButtonElement).disabled = true;
        manualSaveBtn.classList.add('opacity-50', 'cursor-not-allowed');
        
        // Trigger blur to save current field
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Wait a bit to let autosave finish, then re-enable
        setTimeout(() => {
          (manualSaveBtn as HTMLButtonElement).disabled = false;
          manualSaveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }, 700);
      });
    }
  });
</script>
