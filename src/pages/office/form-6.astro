---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.form6.title} formId="Form 6" prevUrl="/office/form-5" nextUrl="/office/form-7">
  
  <div class="p-8 md:p-10">
    <div class="mb-4 flex justify-between items-end">
      <div>
        <h2 class="text-xl font-bold text-slate-800 mb-2">{strings.form6.title}</h2>
        <p class="text-slate-500 text-sm flex gap-4">
          <span class="inline-flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-slate-300"></span>
            {strings.form6.calculationNote}
          </span>
        </p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
      <table class="w-full text-left border-collapse" id="rent-table">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form6.vehicleType}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form6.monthlyAllowance}</th>
            <th class="p-4 font-semibold text-slate-700 w-1/3">{strings.form6.countLabel}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100" id="rent-body">
          <!-- Dynamically populated -->
        </tbody>
      </table>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden py-12 text-center text-slate-500 bg-slate-50 rounded-2xl border border-slate-200 mt-4">
      <p>{strings.form6.noVehicle}</p>
    </div>

  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaCurrency } from '../../lib/bangla.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-6')) return;
    // 1. Session Check
    const officeId = sessionStorage.getItem('office_id');
    const cycleId = sessionStorage.getItem('cycle_id');
    const submissionId = sessionStorage.getItem('submission_id');
    if (!officeId || !cycleId || !submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let isLocked = false;
    let configs = [];
    let formRentData = [];

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Row Logic
    const saveRow = async (configId) => {
      if (isLocked) return;
      showSaving();

      const count = parseInt((document.getElementById(`count-${configId}`) as HTMLInputElement)?.value || '0', 10);

      try {
        if (count === 0) {
          await supabase.from('form_vehicle_rent')
            .delete()
            .eq('submission_id', parseInt(submissionId))
            .eq('vehicle_rent_config_id', parseInt(configId));
        } else {
          const { data: existing } = await supabase.from('form_vehicle_rent')
            .select('id')
            .eq('submission_id', parseInt(submissionId))
            .eq('vehicle_rent_config_id', parseInt(configId))
            .maybeSingle();

          const payload = {
            submission_id: parseInt(submissionId),
            vehicle_rent_config_id: parseInt(configId),
            count
          };

          if (existing) {
            await supabase.from('form_vehicle_rent').update(payload).eq('id', existing.id);
          } else {
            await supabase.from('form_vehicle_rent').insert(payload);
          }
        }
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: configData }, { data: fData }, { data: subData }] = await Promise.all([
        supabase.from('vehicle_rent_config').select(`
          id,
          car_type_id,
          monthly_rent_allowance,
          car_types (name)
        `).order('id'),
        supabase.from('form_vehicle_rent').select('*').eq('submission_id', submissionId),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (configData) configs = configData;
      if (fData) formRentData = fData;
      if (subData && subData.status === 'submitted') isLocked = true;

      const tbody = document.getElementById('rent-body');
      const emptyState = document.getElementById('empty-state');
      const table = document.getElementById('rent-table');

      if (configs.length === 0) {
        table?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        return;
      }

      configs.forEach(config => {
        const rowData = formRentData.find(d => d.vehicle_rent_config_id === config.id) || {};
        const lockAttr = isLocked ? 'disabled' : '';

        const carName = config.car_types?.name || 'Unknown';
        const nameHtml = `<div class="font-bold text-slate-800">${carName}</div>`;
        const allowHtml = `<div class="text-slate-600 font-medium">${toBanglaCurrency(config.monthly_rent_allowance)}</div>`;
        const countHtml = `<input type="number" min="0" id="count-${config.id}" data-config-id="${config.id}" value="${rowData.count || ''}" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none row-input" ${lockAttr} />`;

        const tr = document.createElement('tr');
        tr.className = 'hover:bg-slate-50 transition-colors';
        tr.innerHTML = `
          <td class="p-4 border-r border-slate-100">${nameHtml}</td>
          <td class="p-4 border-r border-slate-100">${allowHtml}</td>
          <td class="p-3">${countHtml}</td>
        `;

        tbody?.appendChild(tr);
      });

      // Attach Event Listeners
      if (!isLocked) {
        const inputs = document.querySelectorAll('.row-input');
        let timeoutMap = new Map();

        inputs.forEach(input => {
          input.addEventListener('blur', (e) => {
            const target = e.target as HTMLInputElement;
            const configId = target.dataset.configId;
            if (!configId) return;

            if (timeoutMap.has(configId)) clearTimeout(timeoutMap.get(configId));
            
            timeoutMap.set(configId, setTimeout(() => {
              saveRow(configId);
            }, 500));
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 6:', err);
    }

    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', () => {
        // Trigger blur on active element to fire auto-save, or just trigger save
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Show saving if not already shown by blur
        const saveIndicator = document.getElementById('save-indicator');
        const saveSpinner = document.getElementById('save-spinner');
        const saveCheck = document.getElementById('save-check');
        const saveText = document.getElementById('save-text');
        
        if (saveIndicator) saveIndicator.classList.remove('opacity-0');
        if (saveSpinner) saveSpinner.classList.remove('hidden');
        if (saveCheck) saveCheck.classList.add('hidden');
        if (saveText) saveText.textContent = strings.saving || 'সংরক্ষণ করা হচ্ছে...';
        
        // Let auto-save handle the actual save, if nothing was active, nothing to save but visual feedback helps
      });
    }
  });
</script>
