---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.forms.form1.title} formId="Form 1">
  
  <div class="p-8 md:p-10">
    <form id="form-basic" class="space-y-8">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Head of Office -->
        <div>
          <label for="head_of_office" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.form1.headOfOffice} <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="head_of_office" 
            name="head_of_office"
            placeholder={strings.form1.headOfOfficePlaceholder}
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all form-input"
          />
        </div>

        <!-- Designation -->
        <div>
          <label for="designation" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.form1.designation} <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="designation" 
            name="designation"
            placeholder={strings.form1.designationPlaceholder}
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all form-input"
          />
        </div>

        <!-- Phone -->
        <div>
          <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.form1.phone} <span class="text-red-500">*</span>
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            placeholder={strings.form1.phonePlaceholder}
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all form-input font-mono"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.form1.email}
          </label>
          <input 
            type="email" 
            id="email" 
            name="email"
            placeholder={strings.form1.emailPlaceholder}
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all form-input font-mono"
          />
        </div>

        <!-- Address -->
        <div class="md:col-span-2">
          <label for="address" class="block text-sm font-semibold text-slate-700 mb-2">
            {strings.form1.address} <span class="text-red-500">*</span>
          </label>
          <textarea 
            id="address" 
            name="address"
            rows="3"
            placeholder={strings.form1.addressPlaceholder}
            class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all form-input resize-none"
          ></textarea>
        </div>
      </div>

    </form>
  </div>

  <a href="/office/form-2" slot="footer-action" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md shadow-blue-500/20 flex items-center gap-2">
    {strings.next}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </a>

</FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';

  document.addEventListener('DOMContentLoaded', async () => {
    // 1. Session Check
    const officeId = sessionStorage.getItem('office_id');
    const cycleId = sessionStorage.getItem('cycle_id');
    const submissionId = sessionStorage.getItem('submission_id');

    if (!officeId || !cycleId || !submissionId) {
      window.location.href = '/';
      return;
    }

    // 2. UI Elements
    const form = document.getElementById('form-basic') as HTMLFormElement;
    const inputs = form.querySelectorAll('.form-input');
    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let rowId = null; // Store the DB row ID if it exists for UPSERT efficiency

    // 3. Load existing data
    try {
      const { data, error } = await supabase
        .from('form_basic')
        .select('*')
        .eq('submission_id', submissionId)
        .maybeSingle();

      if (error) throw error;

      if (data) {
        rowId = data.id;
        (document.getElementById('head_of_office') as HTMLInputElement).value = data.head_of_office || '';
        (document.getElementById('designation') as HTMLInputElement).value = data.designation || '';
        (document.getElementById('phone') as HTMLInputElement).value = data.phone || '';
        (document.getElementById('email') as HTMLInputElement).value = data.email || '';
        (document.getElementById('address') as HTMLInputElement).value = data.address || '';
      }
    } catch (err) {
      console.error('Error loading form_basic:', err);
    }

    // 4. Save Logic
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      
      // Hide after 3 seconds
      setTimeout(() => {
        saveIndicator?.classList.add('opacity-0');
      }, 3000);
    };

    const triggerRecalculation = async () => {
      // Phase 4: Formula engine trigger will go here
      console.log('Budget sheet recalculation triggered.');
    };

    const saveForm = async () => {
      showSaving();

      const payload = {
        submission_id: parseInt(submissionId),
        head_of_office: (document.getElementById('head_of_office') as HTMLInputElement).value.trim(),
        designation: (document.getElementById('designation') as HTMLInputElement).value.trim(),
        phone: (document.getElementById('phone') as HTMLInputElement).value.trim(),
        email: (document.getElementById('email') as HTMLInputElement).value.trim(),
        address: (document.getElementById('address') as HTMLTextAreaElement).value.trim()
      };

      try {
        let query = supabase.from('form_basic');
        
        if (rowId) {
          // Update
          const { error } = await query.update(payload).eq('id', rowId);
          if (error) throw error;
        } else {
          // Insert
          const { data, error } = await query.insert(payload).select().single();
          if (error) throw error;
          if (data) rowId = data.id;
        }

        showSaved();
        await triggerRecalculation();

      } catch (err) {
        console.error('Save error:', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // 5. Debounce Setup
    let timeoutId: number;
    const debouncedSave = () => {
      clearTimeout(timeoutId);
      timeoutId = window.setTimeout(() => {
        saveForm();
      }, 500);
    };

    // Listen to blur on all inputs
    inputs.forEach(input => {
      input.addEventListener('blur', debouncedSave);
    });

  });
</script>
