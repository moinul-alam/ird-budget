---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.forms.form2.title} formId="Form 2" prevUrl="/office/form-1" nextUrl="/office/form-3">
  
  <div class="p-8 md:p-10">
    <!-- Table 1: Grades 1-10 -->
    <div class="mb-12">
      <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 text-blue-700 flex items-center justify-center text-sm">১</span>
        গ্রেড ১-১০
      </h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
        <table class="w-full text-left border-collapse" id="table-1">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th rowspan="2" class="p-4 font-semibold text-slate-700 w-20 border-r border-slate-200 align-middle text-center">গ্রেড</th>
              <th colspan="3" class="p-3 font-bold text-slate-800 text-center border-b border-slate-200 border-r border-slate-200">নিয়মিত</th>
              <th colspan="3" class="p-3 font-bold text-rose-700 text-center border-b border-rose-200 bg-rose-50/50">সাময়িক বরখাস্ত</th>
            </tr>
            <tr class="bg-slate-50 border-b border-slate-200 text-sm">
              <th class="p-3 font-semibold text-slate-600">কর্মরত সংখ্যা</th>
              <th class="p-3 font-semibold text-slate-600">মোট মূল বেতন</th>
              <th class="p-3 font-semibold text-slate-600 border-r border-slate-200">বকেয়া বেতন</th>
              
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">বরখাস্তের সংখ্যা</th>
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">মোট মূল বেতন</th>
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">বকেয়া</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="table-1-body">
            <!-- Dynamically populated -->
          </tbody>
          <tfoot class="bg-blue-50/80 border-t-2 border-blue-200 font-bold text-blue-900">
            <tr>
              <td class="p-4 text-right border-r border-blue-200">মোট:</td>
              <td class="p-4" id="t1-count">০</td>
              <td class="p-4" id="t1-basic">০</td>
              <td class="p-4 border-r border-blue-200"></td>
              
              <td class="p-4 text-rose-800" id="t1-sus-count">০</td>
              <td class="p-4 text-rose-800" id="t1-sus-basic">০</td>
              <td class="p-4"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- Table 2: Grades 11-20 -->
    <div class="mb-6">
      <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm">২</span>
        গ্রেড ১১-২০
      </h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
        <table class="w-full text-left border-collapse" id="table-2">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th rowspan="2" class="p-4 font-semibold text-slate-700 w-20 border-r border-slate-200 align-middle text-center">গ্রেড</th>
              <th colspan="3" class="p-3 font-bold text-slate-800 text-center border-b border-slate-200 border-r border-slate-200">নিয়মিত</th>
              <th colspan="3" class="p-3 font-bold text-rose-700 text-center border-b border-rose-200 bg-rose-50/50">সাময়িক বরখাস্ত</th>
            </tr>
            <tr class="bg-slate-50 border-b border-slate-200 text-sm">
              <th class="p-3 font-semibold text-slate-600">কর্মরত সংখ্যা</th>
              <th class="p-3 font-semibold text-slate-600">মোট মূল বেতন</th>
              <th class="p-3 font-semibold text-slate-600 border-r border-slate-200">বকেয়া বেতন</th>
              
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">বরখাস্তের সংখ্যা</th>
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">মোট মূল বেতন</th>
              <th class="p-3 font-semibold text-rose-600 bg-rose-50/50">বকেয়া</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="table-2-body">
            <!-- Dynamically populated -->
          </tbody>
          <tfoot class="bg-indigo-50/80 border-t-2 border-indigo-200 font-bold text-indigo-900">
            <tr>
              <td class="p-4 text-right border-r border-indigo-200">মোট:</td>
              <td class="p-4" id="t2-count">০</td>
              <td class="p-4" id="t2-basic">০</td>
              <td class="p-4 border-r border-indigo-200"></td>
              
              <td class="p-4 text-rose-800" id="t2-sus-count">০</td>
              <td class="p-4 text-rose-800" id="t2-sus-basic">০</td>
              <td class="p-4"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaNumber } from '../../lib/bangla.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-2')) return;
    // 1. Session Check
    const submissionId = sessionStorage.getItem('submission_id');
    if (!submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let formStaffData = [];
    let grades = [];

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Calculate Totals
    const calculateTotals = () => {
      let t1c = 0, t1b = 0, t1sc = 0, t1sb = 0;
      let t2c = 0, t2b = 0, t2sc = 0, t2sb = 0;

      grades.forEach(grade => {
        const id = grade.id;
        const gNum = grade.grade_no;
        
        const cInp = document.getElementById(`count-${id}`) as HTMLInputElement;
        const bInp = document.getElementById(`basic-${id}`) as HTMLInputElement;
        const scInp = document.getElementById(`sus-count-${id}`) as HTMLInputElement;
        const sbInp = document.getElementById(`sus-basic-${id}`) as HTMLInputElement;
        
        const cVal = parseInt(cInp?.value || '0', 10);
        const bVal = parseInt(bInp?.value || '0', 10);
        const scVal = parseInt(scInp?.value || '0', 10);
        const sbVal = parseInt(sbInp?.value || '0', 10);

        if (gNum <= 10) {
          t1c += cVal; t1b += bVal; t1sc += scVal; t1sb += sbVal;
        } else {
          t2c += cVal; t2b += bVal; t2sc += scVal; t2sb += sbVal;
        }
      });

      document.getElementById('t1-count')!.textContent = toBanglaNumber(t1c);
      document.getElementById('t1-basic')!.textContent = toBanglaNumber(t1b);
      document.getElementById('t1-sus-count')!.textContent = toBanglaNumber(t1sc);
      document.getElementById('t1-sus-basic')!.textContent = toBanglaNumber(t1sb);

      document.getElementById('t2-count')!.textContent = toBanglaNumber(t2c);
      document.getElementById('t2-basic')!.textContent = toBanglaNumber(t2b);
      document.getElementById('t2-sus-count')!.textContent = toBanglaNumber(t2sc);
      document.getElementById('t2-sus-basic')!.textContent = toBanglaNumber(t2sb);
    };

    // Save Row Logic
    const saveRow = async (gradeId) => {
      showSaving();

      const count = parseInt((document.getElementById(`count-${gradeId}`) as HTMLInputElement).value || '0', 10);
      const basic = parseFloat((document.getElementById(`basic-${gradeId}`) as HTMLInputElement).value || '0');
      const due = parseFloat((document.getElementById(`due-${gradeId}`) as HTMLInputElement).value || '0');
      
      const susCount = parseInt((document.getElementById(`sus-count-${gradeId}`) as HTMLInputElement).value || '0', 10);
      const susBasic = parseFloat((document.getElementById(`sus-basic-${gradeId}`) as HTMLInputElement).value || '0');
      const susDue = parseFloat((document.getElementById(`sus-due-${gradeId}`) as HTMLInputElement).value || '0');

      const isZero = count === 0 && basic === 0 && due === 0 && susCount === 0 && susBasic === 0 && susDue === 0;

      try {
        if (isZero) {
          await supabase.from('form_staff').delete()
            .eq('submission_id', parseInt(submissionId))
            .eq('grade_id', gradeId);
        } else {
          const { data: existing } = await supabase.from('form_staff')
            .select('id')
            .eq('submission_id', parseInt(submissionId))
            .eq('grade_id', gradeId)
            .maybeSingle();

          const payload = {
            submission_id: parseInt(submissionId),
            grade_id: gradeId,
            count, total_basic: basic, due_salary: due,
            suspended_count: susCount, suspended_total_basic: susBasic, suspended_due_salary: susDue
          };

          if (existing) {
            await supabase.from('form_staff').update(payload).eq('id', existing.id);
          } else {
            await supabase.from('form_staff').insert(payload);
          }
        }
        
        calculateTotals();
        showSaved();
      } catch (err) {
        console.error('Row save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: gData }, { data: sData }] = await Promise.all([
        supabase.from('grades').select('*').order('grade_no'),
        supabase.from('form_staff').select('*').eq('submission_id', submissionId)
      ]);

      if (gData) grades = gData;
      if (sData) formStaffData = sData;

      const t1Body = document.getElementById('table-1-body');
      const t2Body = document.getElementById('table-2-body');

      grades.forEach(grade => {
        const rowData = formStaffData.find(d => d.grade_id === grade.id) || {};
        const gradeText = toBanglaNumber(grade.grade_no);

        const createInput = (idPref, val, extraClass = "") => `
          <input type="number" min="0" id="${idPref}-${grade.id}" value="${val || ''}" 
                 class="w-full px-2 py-2 bg-white border border-slate-200 rounded focus:ring-2 focus:ring-blue-500 outline-none row-input ${extraClass}" />
        `;

        const tr = document.createElement('tr');
        tr.className = "hover:bg-slate-50 transition-colors";
        tr.innerHTML = `
          <td class="p-3 font-bold text-slate-700 text-center border-r border-slate-100 bg-slate-50/50">${gradeText}</td>
          
          <td class="p-2">${createInput('count', rowData.count)}</td>
          <td class="p-2">${createInput('basic', rowData.total_basic)}</td>
          <td class="p-2 border-r border-slate-100">${createInput('due', rowData.due_salary)}</td>
          
          <td class="p-2 bg-rose-50/30">${createInput('sus-count', rowData.suspended_count, 'border-rose-100 focus:ring-rose-500')}</td>
          <td class="p-2 bg-rose-50/30">${createInput('sus-basic', rowData.suspended_total_basic, 'border-rose-100 focus:ring-rose-500')}</td>
          <td class="p-2 bg-rose-50/30">${createInput('sus-due', rowData.suspended_due_salary, 'border-rose-100 focus:ring-rose-500')}</td>
        `;

        if (grade.grade_no <= 10) {
          t1Body?.appendChild(tr);
        } else {
          t2Body?.appendChild(tr);
        }
      });

      calculateTotals();

      // Attach Event Listeners
      const inputs = document.querySelectorAll('.row-input');
      let timeoutMap = new Map();

      inputs.forEach(input => {
        input.addEventListener('input', calculateTotals);

        input.addEventListener('blur', (e) => {
          const target = e.target as HTMLInputElement;
          const parts = target.id.split('-');
          const gradeId = parts[parts.length - 1]; 

          if (timeoutMap.has(gradeId)) clearTimeout(timeoutMap.get(gradeId));
          
          timeoutMap.set(gradeId, setTimeout(() => {
            saveRow(gradeId);
          }, 500));
        });
      });

    } catch (err) {
      console.error('Error loading form 2:', err);
      alert(strings.errors.loadFailed);
    }


    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', () => {
        // Trigger blur on active element to fire auto-save, or just trigger save
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Show saving if not already shown by blur
        const saveIndicator = document.getElementById('save-indicator');
        const saveSpinner = document.getElementById('save-spinner');
        const saveCheck = document.getElementById('save-check');
        const saveText = document.getElementById('save-text');
        
        if (saveIndicator) saveIndicator.classList.remove('opacity-0');
        if (saveSpinner) saveSpinner.classList.remove('hidden');
        if (saveCheck) saveCheck.classList.add('hidden');
        if (saveText) saveText.textContent = strings.saving || 'সংরক্ষণ করা হচ্ছে...';
        
        // Let auto-save handle the actual save, if nothing was active, nothing to save but visual feedback helps
      });
    }
  });
</script>
