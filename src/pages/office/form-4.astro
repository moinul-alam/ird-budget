---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.forms.form4.title} formId="Form 4">
  
  <div class="p-8 md:p-10 space-y-12">
    
    <!-- Leave Encashment Section -->
    <section>
      <div class="mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {strings.form4.leaveEncashmentTitle}
        </h2>
        <p class="text-slate-500 text-sm mt-1">{strings.form4.calculationNote}</p>
      </div>

      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-6">
        <!-- Officer -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
          <div class="font-bold text-slate-700 text-lg mb-2 md:mb-0">
            {strings.form4.officerSection}
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.basicLabel}</label>
            <input type="number" min="0" id="leave_officer_basic" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.dueLabel}</label>
            <input type="number" min="0" id="leave_officer_due" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
        </div>

        <hr class="border-slate-200" />

        <!-- Staff -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
          <div class="font-bold text-slate-700 text-lg mb-2 md:mb-0">
            {strings.form4.staffSection}
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.basicLabel}</label>
            <input type="number" min="0" id="leave_staff_basic" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.dueLabel}</label>
            <input type="number" min="0" id="leave_staff_due" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
        </div>
      </div>
    </section>

    <!-- Rest & Recreation Section -->
    <section>
      <div class="mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {strings.form4.restRecreationTitle}
        </h2>
      </div>

      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.restRecreationAmount}</label>
            <input type="number" min="0" id="rest_amount" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">{strings.form4.restRecreationDue}</label>
            <input type="number" min="0" id="rest_due" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
          </div>
        </div>
      </div>
    </section>

  </div>

  <a href="/office/form-5" slot="footer-action" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-md shadow-blue-500/20 flex items-center gap-2">
    {strings.next}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </a>

</FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';

  document.addEventListener('DOMContentLoaded', async () => {
    // 1. Session Check
    const officeId = sessionStorage.getItem('office_id');
    const cycleId = sessionStorage.getItem('cycle_id');
    const submissionId = sessionStorage.getItem('submission_id');
    if (!officeId || !cycleId || !submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let existingId = null;
    let isLocked = false;

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Logic (UPSERT)
    const saveData = async () => {
      if (isLocked) return;
      showSaving();

      const oBasic = parseInt((document.getElementById('leave_officer_basic') as HTMLInputElement).value || '0', 10);
      const oDue = parseInt((document.getElementById('leave_officer_due') as HTMLInputElement).value || '0', 10);
      const sBasic = parseInt((document.getElementById('leave_staff_basic') as HTMLInputElement).value || '0', 10);
      const sDue = parseInt((document.getElementById('leave_staff_due') as HTMLInputElement).value || '0', 10);
      const rAmount = parseInt((document.getElementById('rest_amount') as HTMLInputElement).value || '0', 10);
      const rDue = parseInt((document.getElementById('rest_due') as HTMLInputElement).value || '0', 10);

      const payload = {
        submission_id: parseInt(submissionId),
        leave_encashment_officer_basic: oBasic,
        leave_encashment_officer_due: oDue,
        leave_encashment_staff_basic: sBasic,
        leave_encashment_staff_due: sDue,
        rest_recreation_amount: rAmount,
        rest_recreation_due: rDue
      };

      try {
        if (existingId) {
          await supabase.from('form_leave').update(payload).eq('id', existingId);
        } else {
          const { data } = await supabase.from('form_leave').insert(payload).select().single();
          if (data) existingId = data.id;
        }
        showSaved();
      } catch (err) {
        console.error('Save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: formData }, { data: subData }] = await Promise.all([
        supabase.from('form_leave').select('*').eq('submission_id', submissionId).maybeSingle(),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (subData && subData.status === 'submitted') isLocked = true;

      if (formData) {
        existingId = formData.id;
        (document.getElementById('leave_officer_basic') as HTMLInputElement).value = formData.leave_encashment_officer_basic || '';
        (document.getElementById('leave_officer_due') as HTMLInputElement).value = formData.leave_encashment_officer_due || '';
        (document.getElementById('leave_staff_basic') as HTMLInputElement).value = formData.leave_encashment_staff_basic || '';
        (document.getElementById('leave_staff_due') as HTMLInputElement).value = formData.leave_encashment_staff_due || '';
        (document.getElementById('rest_amount') as HTMLInputElement).value = formData.rest_recreation_amount || '';
        (document.getElementById('rest_due') as HTMLInputElement).value = formData.rest_recreation_due || '';
      }

      // Attach Event Listeners
      const inputs = document.querySelectorAll('.form-input');
      
      if (isLocked) {
        inputs.forEach(input => (input as HTMLInputElement).disabled = true);
      } else {
        let saveTimeout;
        inputs.forEach(input => {
          input.addEventListener('blur', () => {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveData, 500);
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 4:', err);
    }
  });
</script>
