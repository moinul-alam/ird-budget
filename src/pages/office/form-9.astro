---
import FormLayout from '../../layouts/FormLayout.astro';
import { strings } from '../../lib/strings.js';
---

<FormLayout title={strings.form9.title} formId="Form 9">
  
  <div class="p-8 md:p-10 space-y-8">
    
    <div class="mb-4">
      <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        {strings.form9.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Rent Section -->
      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-6">
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form9.monthlyBill}</label>
          <p class="text-xs text-slate-500 mb-2">{strings.form9.monthlyBillNote}</p>
          <input type="number" min="0" id="monthly_bill" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
        </div>
        
        <div class="p-4 bg-indigo-50 rounded-xl border border-indigo-100">
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-indigo-800">{strings.form9.vatAmount} (<span id="vat-rate">0</span>%)</span>
            <span id="vat-calc" class="font-bold text-indigo-900">0</span>
          </div>
          <p class="text-xs text-indigo-600/70">{strings.form9.vatNote}</p>
        </div>

        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form9.due}</label>
          <input type="number" min="0" id="due" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
        </div>
      </div>

      <!-- Contract Section -->
      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-6">
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form9.contractStart}</label>
          <p class="text-xs text-slate-500 mb-2">{strings.form9.contractNote}</p>
          <input type="date" id="contract_start_date" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
        </div>

        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1">{strings.form9.contractEnd}</label>
          <p class="text-xs text-slate-500 mb-2">{strings.form9.contractNote}</p>
          <input type="date" id="contract_end_date" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm form-input" />
        </div>
      </div>

    </div>
  </div>

  </FormLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';
  import { toBanglaCurrency, toBanglaNumber } from '../../lib/bangla.js';

  document.addEventListener('astro:page-load', async () => {
    if (!window.location.pathname.includes('/office/form-9')) return;
    // 1. Session Check
    const submissionId = sessionStorage.getItem('submission_id');
    if (!submissionId) {
      window.location.href = '/';
      return;
    }

    const saveIndicator = document.getElementById('save-indicator');
    const saveSpinner = document.getElementById('save-spinner');
    const saveCheck = document.getElementById('save-check');
    const saveText = document.getElementById('save-text');

    let existingId = null;
    let isLocked = false;
    let vatPercentage = 0;

    const monthlyBillInput = document.getElementById('monthly_bill') as HTMLInputElement;
    const dueInput = document.getElementById('due') as HTMLInputElement;
    const startDateInput = document.getElementById('contract_start_date') as HTMLInputElement;
    const endDateInput = document.getElementById('contract_end_date') as HTMLInputElement;
    
    const vatCalcEl = document.getElementById('vat-calc');
    const vatRateEl = document.getElementById('vat-rate');

    const updateVatDisplay = () => {
      const bill = parseInt(monthlyBillInput.value || '0', 10);
      const vatAmount = Math.round(bill * vatPercentage / 100);
      if (vatCalcEl) vatCalcEl.textContent = toBanglaCurrency(vatAmount);
    };

    // Save UI handlers
    const showSaving = () => {
      saveIndicator?.classList.remove('opacity-0');
      saveSpinner?.classList.remove('hidden');
      saveCheck?.classList.add('hidden');
      if (saveText) saveText.textContent = strings.saving;
    };

    const showSaved = () => {
      saveSpinner?.classList.add('hidden');
      saveCheck?.classList.remove('hidden');
      if (saveText) saveText.textContent = strings.saved;
      setTimeout(() => saveIndicator?.classList.add('opacity-0'), 3000);
    };

    // Save Logic (UPSERT)
    const saveData = async () => {
      if (isLocked) return;
      showSaving();

      const payload = {
        submission_id: parseInt(submissionId),
        monthly_bill: parseInt(monthlyBillInput.value || '0', 10),
        due: parseInt(dueInput.value || '0', 10),
        contract_start_date: startDateInput.value || null,
        contract_end_date: endDateInput.value || null
      };

      try {
        if (existingId) {
          await supabase.from('form_house_rent').update(payload).eq('id', existingId);
        } else {
          const { data } = await supabase.from('form_house_rent').insert(payload).select().single();
          if (data) existingId = data.id;
        }
        showSaved();
      } catch (err) {
        console.error('Save error', err);
        if (saveText) saveText.textContent = strings.saveFailed;
        saveSpinner?.classList.add('hidden');
      }
    };

    // Load Data
    try {
      const [{ data: formData }, { data: rateData }, { data: subData }] = await Promise.all([
        supabase.from('form_house_rent').select('*').eq('submission_id', submissionId).maybeSingle(),
        supabase.from('rates').select('value').eq('key', 'vat_percentage').single(),
        supabase.from('submissions').select('status').eq('id', submissionId).single()
      ]);

      if (rateData) {
        vatPercentage = parseFloat(rateData.value);
        if (vatRateEl) vatRateEl.textContent = toBanglaNumber(vatPercentage);
      }

      if (subData && subData.status === 'submitted') isLocked = true;

      if (formData) {
        existingId = formData.id;
        monthlyBillInput.value = formData.monthly_bill || '';
        dueInput.value = formData.due || '';
        startDateInput.value = formData.contract_start_date || '';
        endDateInput.value = formData.contract_end_date || '';
        updateVatDisplay();
      }

      // Attach Event Listeners
      const inputs = document.querySelectorAll('.form-input');
      
      if (isLocked) {
        inputs.forEach(input => (input as HTMLInputElement).disabled = true);
      } else {
        let saveTimeout;
        inputs.forEach(input => {
          input.addEventListener('input', () => {
            if (input.id === 'monthly_bill') updateVatDisplay();
          });
          input.addEventListener('blur', () => {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveData, 500);
          });
        });
      }

    } catch (err) {
      console.error('Error loading form 9:', err);
    }

    // Manual Save Button Logic
    const manualSaveBtn = document.getElementById('manual-save-btn');
    if (manualSaveBtn) {
      manualSaveBtn.addEventListener('click', () => {
        // Trigger blur on active element to fire auto-save, or just trigger save
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }
        
        // Show saving if not already shown by blur
        const saveIndicator = document.getElementById('save-indicator');
        const saveSpinner = document.getElementById('save-spinner');
        const saveCheck = document.getElementById('save-check');
        const saveText = document.getElementById('save-text');
        
        if (saveIndicator) saveIndicator.classList.remove('opacity-0');
        if (saveSpinner) saveSpinner.classList.remove('hidden');
        if (saveCheck) saveCheck.classList.add('hidden');
        if (saveText) saveText.textContent = strings.saving || 'সংরক্ষণ করা হচ্ছে...';
        
        // Let auto-save handle the actual save, if nothing was active, nothing to save but visual feedback helps
      });
    }
  });
</script>
