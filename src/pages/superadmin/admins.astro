---
import SuperAdminLayout from '../../layouts/SuperAdminLayout.astro';
import { strings } from '../../lib/strings.js';
---

<SuperAdminLayout activePath="/superadmin/admins" title={strings.superAdmin.admins.title}>
  
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-800 mb-2">{strings.superAdmin.admins.title}</h1>
      <p class="text-slate-500">প্রশাসক অ্যাকাউন্টসমূহ পরিচালনা করুন</p>
    </div>
    <button id="add-admin-btn" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-xl font-bold shadow-md shadow-purple-600/20 transition-colors flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
      </svg>
      {strings.superAdmin.admins.addAdmin}
    </button>
  </div>

  <!-- Edge Function Notice -->
  <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-xl mb-6 flex items-start gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 mt-0.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
        <p class="text-sm font-bold mb-1">সিস্টেম আর্কিটেকচার নোট</p>
        <p class="text-sm">নিরাপত্তাজনিত কারণে সরাসরি ক্লায়েন্ট-সাইড থেকে নতুন অ্যাডমিন অ্যাকাউন্ট তৈরি করা যায় না। নতুন অ্যাকাউন্ট তৈরির ফর্মটি একটি <code>Supabase Edge Function (POST /functions/v1/create-admin)</code> কল করবে যা <code>service_role</code> কী ব্যবহার করে ব্যবহারকারী তৈরি করবে।</p>
        <p class="text-sm">নিরাপত্তাজনিত কারণে সরাসরি ক্লায়েন্ট-সাইড থেকে নতুন অ্যাডমিন অ্যাকাউন্ট তৈরি করা যায় না। নতুন অ্যাকাউন্ট তৈরির ফর্মটি একটি <code>Supabase Edge Function (POST /functions/v1/create-admin)</code> কল করবে যা <code>service_role</code> কী ব্যবহার করে ব্যবহারকারী তৈরি করবে। ইমেইল স্বয়ংক্রিয়ভাবে ইউজারনেম থেকে তৈরি হবে।</p>
    </div>
  </div>

  <!-- Add Admin Form (Hidden by default) -->
  <div id="add-admin-form-container" class="hidden bg-white p-6 rounded-2xl border border-slate-200 shadow-sm mb-8 relative overflow-hidden">
    <h3 class="text-lg font-bold text-slate-800 mb-4">{strings.superAdmin.admins.addAdmin}</h3>
    <form id="add-admin-form" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 items-end relative z-10">
      
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">{strings.superAdmin.admins.username}</label>
        <input type="text" id="new-username" required placeholder="যেমন: admin_dhaka" class="w-full px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none">
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">পাসওয়ার্ড</label>
        <input type="password" id="new-password" required placeholder="••••••••" class="w-full px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none">
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">{strings.superAdmin.admins.role}</label>
        <select id="new-role" required class="w-full px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none bg-white">
          <option value="admin">অ্যাডমিন (Admin)</option>
          <option value="superadmin">সুপার অ্যাডমিন (SuperAdmin)</option>
        </select>
      </div>

      <div class="col-span-1 md:col-span-2 lg:col-span-3 flex gap-2 justify-end mt-2">
        <button type="button" id="cancel-admin-btn" class="px-6 py-2 border border-slate-300 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">
          {strings.cancel}
        </button>
        <button type="submit" id="save-admin-btn" class="px-6 py-2 bg-purple-600 text-white font-bold rounded-xl hover:bg-purple-700 transition-colors shadow-md shadow-purple-500/20">
          তৈরি করুন (Edge Function)
        </button>
      </div>
    </form>
  </div>

  <div id="loading-state" class="py-12 flex flex-col items-center justify-center">
    <div class="w-10 h-10 border-4 border-purple-200 border-t-purple-600 rounded-full animate-spin mb-4"></div>
  </div>

  <!-- Admins Table -->
  <div id="admins-container" class="hidden bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="p-4 font-bold text-slate-600">{strings.superAdmin.admins.username}</th>
            <th class="p-4 font-bold text-slate-600">ভূমিকা (Role)</th>
            <th class="p-4 font-bold text-slate-600 text-center">স্ট্যাটাস</th>
            <th class="p-4 font-bold text-slate-600 text-right">অ্যাকশন</th>
          </tr>
        </thead>
        <tbody id="admins-body" class="divide-y divide-slate-100">
          <!-- Populated via JS -->
        </tbody>
      </table>
    </div>
  </div>

</SuperAdminLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { strings } from '../../lib/strings.js';

  document.addEventListener('DOMContentLoaded', async () => {
    const loadingState = document.getElementById('loading-state');
    const container = document.getElementById('admins-container');
    const tbody = document.getElementById('admins-body');
    
    const addBtn = document.getElementById('add-admin-btn');
    const addFormContainer = document.getElementById('add-admin-form-container');
    const cancelAddBtn = document.getElementById('cancel-admin-btn');
    const addForm = document.getElementById('add-admin-form');

    let adminsData = [];
    const currentUsername = sessionStorage.getItem('sa_username');

    const loadAdmins = async () => {
      try {
        // We fetch from admin_profiles. We cannot fetch emails securely from auth.users without edge function, 
        // so we omit email in this simple listing or it could be added via an RPC call.
        const { data, error } = await supabase
          .from('admin_profiles')
          .select('auth_id, username, role, active')
          .order('username', { ascending: true });

        if (error) throw error;
        adminsData = data || [];
        renderTable();
      } catch (err) {
        console.error(err);
        if (tbody) tbody.innerHTML = `<tr><td colspan="4" class="p-4 text-center text-rose-500">ডেটা লোড করতে সমস্যা হয়েছে।</td></tr>`;
      } finally {
        loadingState?.classList.add('hidden');
        container?.classList.remove('hidden');
      }
    };

    const renderTable = () => {
      if (!tbody) return;
      tbody.innerHTML = '';

      if (adminsData.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-slate-500">কোনো তথ্য পাওয়া যায়নি</td></tr>`;
        return;
      }

      adminsData.forEach(admin => {
        const tr = document.createElement('tr');
        tr.className = 'hover:bg-slate-50 transition-colors group';
        
        const isSelf = admin.username === currentUsername;
        const activeClass = admin.active ? 'bg-emerald-500' : 'bg-slate-300';
        
        const roleBadge = admin.role === 'superadmin' 
          ? `<span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-purple-100 text-purple-800">SuperAdmin</span>`
          : `<span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-100 text-blue-800">Admin</span>`;

        // Role toggle select
        const roleSelect = isSelf ? roleBadge : `
            <select data-id="${admin.auth_id}" class="role-select px-2 py-1 border border-slate-300 rounded-lg text-sm outline-none focus:ring-1 focus:ring-purple-500 bg-white">
                <option value="admin" ${admin.role === 'admin' ? 'selected' : ''}>Admin</option>
                <option value="superadmin" ${admin.role === 'superadmin' ? 'selected' : ''}>SuperAdmin</option>
            </select>
        `;

        tr.innerHTML = `
          <td class="p-4 font-medium text-slate-800 flex items-center gap-2">
            ${admin.username}
            ${isSelf ? '<span class="text-[10px] bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded uppercase font-bold tracking-wider">You</span>' : ''}
          </td>
          <td class="p-4">${roleSelect}</td>
          <td class="p-4 text-center">
            ${isSelf 
              ? `<span class="inline-block h-4 w-4 rounded-full bg-emerald-500"></span>` 
              : `<button data-id="${admin.auth_id}" data-active="${admin.active}" class="toggle-active-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none ${activeClass}">
                   <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${admin.active ? 'translate-x-6' : 'translate-x-1'}"></span>
                 </button>`
            }
          </td>
          <td class="p-4 text-right">
             <!-- Additional actions could go here -->
          </td>
        `;
        tbody.appendChild(tr);
      });

      bindActions();
    };

    const bindActions = () => {
      // 1. Toggle Active Status
      document.querySelectorAll('.toggle-active-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const id = target.getAttribute('data-id');
          const currentActive = target.getAttribute('data-active') === 'true';
          const newActive = !currentActive;

          target.disabled = true;
          try {
            await supabase.from('admin_profiles').update({ active: newActive }).eq('auth_id', id);
            
            // Visual update
            target.setAttribute('data-active', String(newActive));
            target.className = `toggle-active-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none ${newActive ? 'bg-emerald-500' : 'bg-slate-300'}`;
            target.innerHTML = `<span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${newActive ? 'translate-x-6' : 'translate-x-1'}"></span>`;
            
            // Update local state
            const admin = adminsData.find(a => a.auth_id == id);
            if(admin) admin.active = newActive;
            
          } catch(err) {
             alert('সংরক্ষণ ব্যর্থ হয়েছে');
          } finally {
            target.disabled = false;
          }
        });
      });

      // 2. Change Role
      document.querySelectorAll('.role-select').forEach(select => {
          select.addEventListener('change', async (e) => {
             const target = e.currentTarget as HTMLSelectElement;
             const id = target.getAttribute('data-id');
             const newRole = target.value;

             target.disabled = true;
             try {
                 await supabase.from('admin_profiles').update({ role: newRole }).eq('auth_id', id);
                 const admin = adminsData.find(a => a.auth_id == id);
                 if(admin) admin.role = newRole;
                 // Visual toast
                 target.classList.add('bg-emerald-50', 'border-emerald-500', 'text-emerald-700');
                 setTimeout(() => {
                     target.classList.remove('bg-emerald-50', 'border-emerald-500', 'text-emerald-700');
                 }, 1000);
             } catch (err) {
                 alert('ভূমিকা পরিবর্তন ব্যর্থ হয়েছে');
                 // Revert selection visually
                 target.value = adminsData.find(a => a.auth_id == id).role;
             } finally {
                 target.disabled = false;
             }
          });
      });
    };

    // Form Handlers
    addBtn?.addEventListener('click', () => {
      addFormContainer?.classList.remove('hidden');
    });

    cancelAddBtn?.addEventListener('click', () => {
      addFormContainer?.classList.add('hidden');
      (addForm as HTMLFormElement).reset();
    });

    addForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const username = (document.getElementById('new-username') as HTMLInputElement).value.trim();
      const password = (document.getElementById('new-password') as HTMLInputElement).value;
      const role = (document.getElementById('new-role') as HTMLSelectElement).value;
      const submitBtn = document.getElementById('save-admin-btn') as HTMLButtonElement;

      const email = `${username}@ird-budget.local`;

      submitBtn.disabled = true;
      submitBtn.textContent = 'কল করা হচ্ছে...';

      try {
        // =========================================================================
        // EDGE FUNCTION MOCKUP
        // =========================================================================
        // This is where we would call the Edge Function to securely create the user
        // and insert into the admin_profiles table using service_role key.
        console.log('Would call Edge Function: POST /functions/v1/create-admin');
        console.log('Payload:', { email, password, username, role });
        
        // Simulating network delay
        await new Promise(r => setTimeout(r, 1000));
        
        alert('সফলভাবে তৈরি হয়েছে (Mocked Edge Function Call)');

        // Clear form
        (addForm as HTMLFormElement).reset();
        addFormContainer?.classList.add('hidden');
        await loadAdmins();
      } catch (err) {
        console.error(err);
        alert(strings.errors.saveFailed);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'তৈরি করুন (Edge Function)';
      }
    });

    // Initial load
    loadAdmins();
  });
</script>
