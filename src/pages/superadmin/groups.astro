---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-6xl mx-auto">
      <a href="/superadmin/dashboard" class="text-blue-600 mb-4 inline-block">&larr; পিছনে</a>
      <h1 class="text-2xl font-bold mb-6">অফিস গ্রুপ</h1>
      <div id="message" class="hidden mb-4 p-4 rounded"></div>
      
      <div class="bg-white p-6 rounded shadow mb-6">
        <h2 class="text-xl font-bold mb-4">নতুন গ্রুপ যোগ করুন</h2>
        <form id="add-group-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block mb-2 font-medium">নাম</label>
            <input type="text" id="group-name" class="w-full p-2 border border-gray-300 rounded" required />
          </div>
          <div>
            <label class="block mb-2 font-medium">বিবরণ</label>
            <input type="text" id="group-description" class="w-full p-2 border border-gray-300 rounded" />
          </div>
          <div class="md:col-span-2">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">গ্রুপ যোগ করুন</button>
          </div>
        </form>
      </div>

      <div class="bg-white rounded shadow overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100">
            <tr>
              <th class="p-3 text-left">নাম</th>
              <th class="p-3 text-left">বিবরণ</th>
              <th class="p-3 text-left">কার্যক্রম</th>
            </tr>
          </thead>
          <tbody id="groups-table"></tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    import { supabase } from '../../lib/supabase';

    function showMessage(message, isError = false) {
      const el = document.getElementById('message');
      el.textContent = message;
      el.className = `mb-4 p-4 rounded ${isError ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'}`;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 3000);
    }

    async function loadGroups() {
      const { data: groups } = await supabase.from('office_groups').select('*');
      const table = document.getElementById('groups-table');
      table.innerHTML = (groups || []).map(group => `
        <tr class="border-b" data-id="${group.id}">
          <td class="p-3">
            <input type="text" class="w-full p-2 border border-gray-300 rounded group-name" value="${group.name}" />
          </td>
          <td class="p-3">
            <input type="text" class="w-full p-2 border border-gray-300 rounded group-desc" value="${group.description || ''}" />
          </td>
          <td class="p-3 space-x-2">
            <button class="text-blue-600 hover:underline save-btn">সংরক্ষণ</button>
            <button class="text-red-600 hover:underline delete-btn">মুছুন</button>
          </td>
        </tr>
      `).join('');

      document.querySelectorAll('.save-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const row = btn.closest('tr');
          const id = row.dataset.id;
          const name = row.querySelector('.group-name').value;
          const description = row.querySelector('.group-desc').value;

          const { error } = await supabase.from('office_groups').update({ name, description }).eq('id', id);
          if (error) {
            showMessage('গ্রুপ আপডেট করতে সমস্যা হয়েছে: ' + error.message, true);
          } else {
            showMessage('গ্রুপ সফলভাবে আপডেট হয়েছে!');
            loadGroups();
          }
        });
      });

      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('আপনি কি নিশ্চিত?')) return;
          const row = btn.closest('tr');
          const id = row.dataset.id;
          const { error } = await supabase.from('office_groups').delete().eq('id', id);
          if (error) {
            showMessage('গ্রুপ মুছতে সমস্যা হয়েছে: ' + error.message, true);
          } else {
            showMessage('গ্রুপ সফলভাবে মুছে ফেলা হয়েছে!');
            loadGroups();
          }
        });
      });
    }

    document.getElementById('add-group-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('group-name').value.trim();
      const description = document.getElementById('group-description').value.trim();
      
      const { error } = await supabase.from('office_groups').insert([{ name, description }]);
      if (error) {
        showMessage('গ্রুপ যোগ করতে সমস্যা হয়েছে: ' + error.message, true);
      } else {
        showMessage('গ্রুপ সফলভাবে যোগ করা হয়েছে!');
        document.getElementById('add-group-form').reset();
        loadGroups();
      }
    });

    loadGroups();
  </script>
</Layout>
