---
import SuperAdminLayout from '../../layouts/SuperAdminLayout.astro';
import { strings } from '../../lib/strings.js';
---

<SuperAdminLayout activePath="/superadmin/dashboard">
  
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800 mb-2">{strings.superAdmin.dashboard}</h1>
    <p class="text-slate-500">সিস্টেমের সার্বিক অবস্থা একনজরে দেখুন</p>
  </div>

  <div id="loading-state" class="min-h-[40vh] flex flex-col items-center justify-center">
    <div class="w-12 h-12 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin mb-4"></div>
    <p class="text-slate-500 font-medium">{strings.loading}</p>
  </div>

  <div id="dashboard-content" class="hidden opacity-0 transition-opacity duration-500">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- Cycles Card -->
      <a href="/superadmin/cycles" class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="cycles-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">{strings.superAdmin.cycles.title}</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg flex justify-between">
          <span>খোলা: <strong class="text-emerald-600" id="cycles-open">০</strong></span>
          <span>বন্ধ: <strong class="text-rose-600" id="cycles-closed">০</strong></span>
        </div>
      </a>

      <!-- Submissions Card -->
      <a href="/superadmin/submissions" class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 text-indigo-600 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="submissions-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">দাখিলকৃত বাজেট</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg flex justify-between gap-2">
          <span>দাখিলকৃত: <strong class="text-emerald-600" id="subs-submitted">০</strong></span>
          <span>খসড়া: <strong class="text-amber-500" id="subs-draft">০</strong></span>
          <span>ফেরত: <strong class="text-rose-500" id="subs-resubmit">০</strong></span>
        </div>
      </a>

      <!-- Offices Card -->
      <div class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="offices-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">{strings.admin.dashboard.totalOffices}</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg text-center">
          নিবন্ধিত অফিস (ভিউ অনলি)
        </div>
      </div>

      <!-- Expense Codes Card -->
      <a href="/superadmin/expense-codes" class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="codes-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">{strings.superAdmin.codes.title}</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg text-center">
          সক্রিয় খাতসমূহ
        </div>
      </a>

      <!-- Rates Card -->
      <a href="/superadmin/rates" class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-rose-100 text-rose-600 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="rates-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">{strings.superAdmin.rates.title}</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg text-center">
          ফর্মুলা হার
        </div>
      </a>

      <!-- Admins Card -->
      <a href="/superadmin/admins" class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all block">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-800" id="admins-count">০</div>
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wider">{strings.superAdmin.admins.title}</div>
          </div>
        </div>
        <div class="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg flex justify-between">
          <span>মোট: <strong class="text-slate-800" id="admins-total">০</strong></span>
          <span>সক্রিয়: <strong class="text-emerald-600" id="admins-active">০</strong></span>
        </div>
      </a>

    </div>
  </div>
</SuperAdminLayout>

<script>
  import { supabase } from '../../lib/supabase.js';
  import { toBanglaNumber } from '../../lib/bangla.js';

  document.addEventListener('DOMContentLoaded', async () => {
    try {
      // Fetch all required data in parallel
      const [
        { data: cycles },
        { data: submissions },
        { count: officesCount },
        { data: codes },
        { count: ratesCount },
        { data: admins }
      ] = await Promise.all([
        supabase.from('cycles').select('status'),
        supabase.from('submissions').select('status'),
        supabase.from('offices').select('*', { count: 'exact', head: true }),
        supabase.from('expense_codes').select('active'),
        supabase.from('rates').select('*', { count: 'exact', head: true }),
        supabase.from('admin_profiles').select('active')
      ]);

      // Process Cycles
      const openCycles = cycles?.filter(c => c.status === 'open').length || 0;
      const closedCycles = cycles?.filter(c => c.status === 'closed').length || 0;
      
      const elCyclesCount = document.getElementById('cycles-count');
      const elCyclesOpen = document.getElementById('cycles-open');
      const elCyclesClosed = document.getElementById('cycles-closed');
      
      if (elCyclesCount) elCyclesCount.textContent = toBanglaNumber(openCycles + closedCycles);
      if (elCyclesOpen) elCyclesOpen.textContent = toBanglaNumber(openCycles);
      if (elCyclesClosed) elCyclesClosed.textContent = toBanglaNumber(closedCycles);

      // Process Submissions
      const subSubmitted = submissions?.filter(s => s.status === 'submitted').length || 0;
      const subDraft = submissions?.filter(s => s.status === 'draft').length || 0;
      const subResubmit = submissions?.filter(s => s.status === 'needs_resubmit').length || 0;

      const elSubsCount = document.getElementById('submissions-count');
      const elSubsSub = document.getElementById('subs-submitted');
      const elSubsDraft = document.getElementById('subs-draft');
      const elSubsResubmit = document.getElementById('subs-resubmit');

      if (elSubsCount) elSubsCount.textContent = toBanglaNumber(submissions?.length || 0);
      if (elSubsSub) elSubsSub.textContent = toBanglaNumber(subSubmitted);
      if (elSubsDraft) elSubsDraft.textContent = toBanglaNumber(subDraft);
      if (elSubsResubmit) elSubsResubmit.textContent = toBanglaNumber(subResubmit);

      // Process Offices
      const elOfficesCount = document.getElementById('offices-count');
      if (elOfficesCount) elOfficesCount.textContent = toBanglaNumber(officesCount || 0);

      // Process Expense Codes
      const activeCodes = codes?.filter(c => c.active).length || 0;
      const elCodesCount = document.getElementById('codes-count');
      if (elCodesCount) elCodesCount.textContent = toBanglaNumber(activeCodes);

      // Process Rates
      const elRatesCount = document.getElementById('rates-count');
      if (elRatesCount) elRatesCount.textContent = toBanglaNumber(ratesCount || 0);

      // Process Admins
      const activeAdmins = admins?.filter(a => a.active).length || 0;
      const totalAdmins = admins?.length || 0;
      
      const elAdminsCount = document.getElementById('admins-count');
      const elAdminsTotal = document.getElementById('admins-total');
      const elAdminsActive = document.getElementById('admins-active');

      if (elAdminsCount) elAdminsCount.textContent = toBanglaNumber(activeAdmins);
      if (elAdminsTotal) elAdminsTotal.textContent = toBanglaNumber(totalAdmins);
      if (elAdminsActive) elAdminsActive.textContent = toBanglaNumber(activeAdmins);

      // Show content
      document.getElementById('loading-state')?.classList.add('hidden');
      const content = document.getElementById('dashboard-content');
      if (content) {
        content.classList.remove('hidden');
        setTimeout(() => content.classList.remove('opacity-0'), 50);
      }

    } catch (err) {
      console.error('Dashboard load error', err);
      const loadingState = document.getElementById('loading-state');
      if (loadingState) {
        loadingState.innerHTML = '<p class="text-rose-500">ডেটা লোড করতে সমস্যা হয়েছে।</p>';
      }
    }
  });
</script>
