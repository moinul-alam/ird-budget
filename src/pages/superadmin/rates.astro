---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-6xl mx-auto">
      <a href="/superadmin/dashboard" class="text-blue-600 mb-4 inline-block">&larr; পিছনে</a>
      <h1 class="text-2xl font-bold mb-6">রেট</h1>
      <div id="message" class="hidden mb-4 p-4 rounded"></div>
      <div class="bg-white rounded shadow overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100">
            <tr>
              <th class="p-3 text-left">কী</th>
              <th class="p-3 text-left">মান</th>
              <th class="p-3 text-left">বিবরণ</th>
              <th class="p-3 text-left">কার্যক্রম</th>
            </tr>
          </thead>
          <tbody id="rates-table"></tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    import { supabase } from '../../lib/supabase';
    import { calculateBudget } from '../../lib/formulas';

    function showMessage(message, isError = false) {
      const el = document.getElementById('message');
      el.textContent = message;
      el.className = `mb-4 p-4 rounded ${isError ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'}`;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 3000);
    }

    async function recalculateAllBudgets() {
      const { data: cycle } = await supabase.from('cycles').select('*').eq('status', 'open').maybeSingle();
      if (!cycle) return;

      const { data: submissions } = await supabase.from('submissions').select('*').eq('cycle_id', cycle.id).eq('status', 'draft');

      const { data: codes } = await supabase.from('expense_codes').select('*');
      const { data: ratesData } = await supabase.from('rates').select('*');
      const rates = {};
      ratesData.forEach(r => rates[r.key] = r.value);

      for (const submission of (submissions || [])) {
        const { data: formStaff } = await supabase.from('form_staff').select('*, grades(*)').eq('submission_id', submission.id);
        const { data: formFuel } = await supabase.from('form_fuel').select('*').eq('submission_id', submission.id);
        const { data: formUtility } = await supabase.from('form_utility').select('*').eq('submission_id', submission.id).maybeSingle();
        const { data: formRent } = await supabase.from('form_rent').select('*').eq('submission_id', submission.id).maybeSingle();
        const { data: formMisc } = await supabase.from('form_misc').select('*').eq('submission_id', submission.id).maybeSingle();

        const submissionData = {
          staff: (formStaff || []).map(s => ({
            grade_no: s.grades?.grade_no,
            count: s.count,
            avg_basic: s.avg_basic
          })),
          fuel: formFuel || [],
          utility: formUtility || {},
          rent: formRent || {},
          misc: formMisc || {}
        };

        const budgetData = calculateBudget(submissionData, codes, rates);

        for (const row of budgetData) {
          const { data: existing } = await supabase.from('budget_sheet').select('*').eq('submission_id', submission.id).eq('code_id', row.code_id).maybeSingle();
          if (existing) {
            await supabase.from('budget_sheet').update({ auto_value: row.auto_value }).eq('id', existing.id);
          } else {
            await supabase.from('budget_sheet').insert([{ submission_id: submission.id, code_id: row.code_id, auto_value: row.auto_value }]);
          }
        }
      }
    }

    async function loadRates() {
      const { data: rates } = await supabase.from('rates').select('*');
      const table = document.getElementById('rates-table');
      table.innerHTML = (rates || []).map(rate => `
        <tr class="border-b" data-id="${rate.id}">
          <td class="p-3">
            <input type="text" class="w-full p-2 border border-gray-300 rounded rate-key" value="${rate.key}" />
          </td>
          <td class="p-3">
            <input type="number" class="w-full p-2 border border-gray-300 rounded rate-value" value="${rate.value}" />
          </td>
          <td class="p-3">
            <input type="text" class="w-full p-2 border border-gray-300 rounded rate-desc" value="${rate.description || ''}" />
          </td>
          <td class="p-3 space-x-2">
            <button class="text-blue-600 hover:underline save-btn">সংরক্ষণ</button>
            <button class="text-red-600 hover:underline delete-btn">মুছুন</button>
          </td>
        </tr>
      `).join('');

      document.querySelectorAll('.save-btn').forEach((btn, i) => {
        btn.addEventListener('click', async () => {
          const row = btn.closest('tr');
          const id = row.dataset.id;
          const key = row.querySelector('.rate-key').value;
          const value = parseFloat(row.querySelector('.rate-value').value);
          const description = row.querySelector('.rate-desc').value;

          const { error } = await supabase.from('rates').update({ key, value, description, updated_at: new Date().toISOString() }).eq('id', id);
          if (error) {
            showMessage('রেট আপডেট করতে সমস্যা হয়েছে: ' + error.message, true);
          } else {
            showMessage('রেট সফলভাবে আপডেট হয়েছে!');
            await recalculateAllBudgets();
            showMessage('সব খসড়া বাজেট পুনরায় গণনা করা হয়েছে!');
          }
        });
      });

      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('আপনি কি নিশ্চিত?')) return;
          const row = btn.closest('tr');
          const id = row.dataset.id;
          const { error } = await supabase.from('rates').delete().eq('id', id);
          if (error) {
            showMessage('রেট মুছতে সমস্যা হয়েছে: ' + error.message, true);
          } else {
            showMessage('রেট সফলভাবে মুছে ফেলা হয়েছে!');
            loadRates();
          }
        });
      });
    }

    loadRates();
  </script>
</Layout>
